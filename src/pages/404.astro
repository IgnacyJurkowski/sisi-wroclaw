---
// Static 404 defaults to Polish; the language selector lets visitors switch.
import Base from '../layouts/Base.astro';
import { DEFAULT_LOCALE } from '../i18n/config';
import { localizedPath } from '../i18n/routes';
import { useTranslations } from '../i18n/t';

const locale = DEFAULT_LOCALE;
const t = useTranslations(locale);
const homeHref = localizedPath('home', locale);
const eventsHref = localizedPath('events', locale);
---

<Base locale={locale} title={t.meta.notFound.title} description={t.meta.notFound.description} noindex>
  <section class="nf">
    <span class="page-label">{t.notFound.label}</span>
    <h1 class="display nf-title">{t.notFound.title}</h1>
    <p class="nf-body">{t.notFound.body}</p>
    <div class="nf-actions">
      <a href={homeHref} class="btn-cta">{t.buttons.home}</a>
      <a href={eventsHref} class="btn-outline">{t.nav.events}</a>
    </div>
  </section>
</Base>

<style>
  .nf {
    min-height: 78vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    padding: calc(var(--nav-height) + 2rem) 24px 4rem;
    max-width: 620px; margin: 0 auto;
  }
  .nf-title { font-size: clamp(2.4rem, 7vw, 4.5rem); text-transform: uppercase; margin: 12px 0 18px; line-height: 1.05; }
  .nf-body { color: var(--text-dim); font-size: 16px; line-height: 1.8; margin-bottom: 32px; }
  .nf-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
</style>
