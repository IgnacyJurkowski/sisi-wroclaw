---
import Base from '../layouts/Base.astro';
---

<Base
  title="404 - Nie znaleziono strony | SiSi Wrocław"
  description="Strona, której szukasz, nie istnieje. Wróć na stronę główną SiSi Wrocław."
  path="/404"
>
  <section class="nf">
    <span class="page-label">Błąd 404</span>
    <h1 class="display nf-title">Tej strony nie ma</h1>
    <p class="nf-body">
      Wygląda na to, że strona, której szukasz, zniknęła jak ostatni gość o świcie.
      Wróć na stronę główną albo sprawdź, co u nas gramy.
    </p>
    <div class="nf-actions">
      <a href="/" class="btn-cta">Strona główna</a>
      <a href="/wydarzenia" class="btn-outline">Wydarzenia</a>
    </div>
  </section>
</Base>

<style>
  .nf {
    min-height: 78vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    padding: calc(var(--nav-height) + 2rem) 24px 4rem;
    max-width: 620px; margin: 0 auto;
  }
  .nf-title { font-size: clamp(2.4rem, 7vw, 4.5rem); text-transform: uppercase; margin: 12px 0 18px; line-height: 1.05; }
  .nf-body { color: var(--text-dim); font-size: 16px; line-height: 1.8; margin-bottom: 32px; }
  .nf-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
</style>
