---
import { LOCALES, type Locale } from '../i18n/config';
import { ROUTE_KEYS, SLUGS, type RouteKey } from '../i18n/routes';
import HomePage from '../components/pages/HomePage.astro';
import EventsPage from '../components/pages/EventsPage.astro';
import MenuPage from '../components/pages/MenuPage.astro';
import CareersPage from '../components/pages/CareersPage.astro';
import ReservationsPage from '../components/pages/ReservationsPage.astro';
import ContactPage from '../components/pages/ContactPage.astro';
import CorporatePage from '../components/pages/CorporatePage.astro';
import PrivateEventsPage from '../components/pages/PrivateEventsPage.astro';
import LegalPage from '../components/pages/LegalPage.astro';
import EventDetailPage from '../components/pages/EventDetailPage.astro';
import { EVENTS, type EventItem } from '../data/site';

// One static page per (locale, route) from the central route map, plus one
// detail page per (locale, event) nested under the localized events slug.
export function getStaticPaths() {
  const paths: {
    params: { path: string };
    props: { locale: Locale; routeKey: RouteKey; event?: EventItem };
  }[] = [];
  for (const locale of LOCALES) {
    for (const key of ROUTE_KEYS) {
      const slug = SLUGS[key][locale];
      const path = slug ? `${locale}/${slug}` : `${locale}`;
      paths.push({ params: { path }, props: { locale, routeKey: key } });
    }
    for (const event of EVENTS) {
      paths.push({
        params: { path: `${locale}/${SLUGS.events[locale]}/${event.slug}` },
        props: { locale, routeKey: 'events', event },
      });
    }
  }
  return paths;
}

const { locale, routeKey, event } = Astro.props;
---

{event && <EventDetailPage locale={locale} event={event} />}
{routeKey === 'home' && <HomePage locale={locale} />}
{!event && routeKey === 'events' && <EventsPage locale={locale} />}
{routeKey === 'menu' && <MenuPage locale={locale} />}
{routeKey === 'careers' && <CareersPage locale={locale} />}
{routeKey === 'reservations' && <ReservationsPage locale={locale} />}
{routeKey === 'corporate' && <CorporatePage locale={locale} />}
{routeKey === 'privateEvents' && <PrivateEventsPage locale={locale} />}
{routeKey === 'contact' && <ContactPage locale={locale} />}
{(routeKey === 'terms' || routeKey === 'privacy' || routeKey === 'cookies') && (
  <LegalPage locale={locale} legalKey={routeKey} />
)}
