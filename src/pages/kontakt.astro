---
import Base from '../layouts/Base.astro';
import { CONTACT, COMPANY, LEGAL_UPDATED } from '../data/site';

const mapHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(CONTACT.address)}`;
---

<Base
  title="Kontakt - SiSi Wrocław"
  description="Dane kontaktowe i informacje o podmiocie prowadzącym klub SiSi Wrocław - adres, telefon, e-mail oraz dane rejestrowe (NIP, REGON, KRS)."
  ogDescription="Dane kontaktowe i rejestrowe klubu SiSi Wrocław."
  path="/kontakt"
>
  <div class="page-header" data-reveal>
    <span class="page-label">Informacje</span>
    <h1 class="page-title display">Kontakt</h1>
    <p class="page-subtitle">Rezerwacje, eventy firmowe oraz dane rejestrowe podmiotu prowadzącego klub SiSi.</p>
  </div>

  <div class="legal" data-reveal>
    <div class="contact-cols">
      <section>
        <h2>Kontakt</h2>
        <p>
          <strong>Rezerwacje stolików</strong><br />
          <a href={CONTACT.phoneHref}>{CONTACT.phone}</a><br />
          <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
        </p>
        <p>
          <strong>Eventy firmowe</strong><br />
          <a href={CONTACT.eventsPhoneHref}>{CONTACT.eventsPhone}</a><br />
          <a href={`mailto:${CONTACT.eventsEmail}`}>{CONTACT.eventsEmail}</a>
        </p>
        <p>
          <strong>Adres</strong><br />
          <a href={mapHref} rel="noopener" target="_blank">{COMPANY.street}, {COMPANY.postalCity}</a>
        </p>
        <p>
          <strong>Godziny otwarcia</strong><br />
          {CONTACT.hoursLabel}, {CONTACT.hours}
        </p>
      </section>

      <section>
        <h2>Dane rejestrowe</h2>
        <p>Podmiotem prowadzącym klub SiSi oraz administratorem danych osobowych jest:</p>
        <ul>
          <li><strong>{COMPANY.legalName}</strong></li>
          <li>{COMPANY.street}, {COMPANY.postalCity}</li>
          <li>NIP: {COMPANY.nip}</li>
          <li>REGON: {COMPANY.regon}</li>
          <li>KRS: {COMPANY.krs}</li>
        </ul>
        <p class="legal-note">
          Dane rejestrowe wymagają uzupełnienia o rzeczywiste informacje firmy
          przed publikacją.
        </p>
      </section>
    </div>

    <p class="legal-meta">Ostatnia aktualizacja: {LEGAL_UPDATED}</p>
  </div>
</Base>
