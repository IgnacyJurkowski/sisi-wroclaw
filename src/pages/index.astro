---
// Root: send visitors to the default-locale home. A Netlify 301 (netlify.toml)
// is the authoritative redirect for crawlers; this page is the build-time/local
// fallback and is noindexed so it never competes with /pl/.
import { DEFAULT_LOCALE } from '../i18n/config';
import { localizedPath } from '../i18n/routes';

const target = localizedPath('home', DEFAULT_LOCALE); // /pl/
const canonical = new URL(target, Astro.site).href;
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SiSi Wrocław - Music Club & Bar</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={canonical} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <script is:inline>location.replace('/pl/');</script>
  </head>
  <body>
    <a href={target}>SiSi Wrocław</a>
  </body>
</html>
