---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** nav item id to mark as current */
  active?: string;
  /** path appended to the site origin for the canonical/og url, e.g. "/menu" */
  path?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const { title, description, active, path = '', ogTitle, ogDescription } = Astro.props;
const canonical = new URL(path, Astro.site).href;
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <!-- Mark JS as available before paint so reveal elements can start hidden
         without ever hiding content from no-JS clients. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <link rel="canonical" href={canonical} />
  </head>
  <body>
    <Nav active={active} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>import '../scripts/nav.ts';</script>
    <script>import '../scripts/scroll-animations.ts';</script>
  </body>
</html>
