---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** nav item id to mark as current */
  active?: string;
  /** path appended to the site origin for the canonical/og url, e.g. "/menu" */
  path?: string;
  ogTitle?: string;
  ogDescription?: string;
  /** above-the-fold hero image to preload (desktop variant) */
  preloadImage?: string;
  /** lighter hero image preloaded on phones (<=820px) */
  preloadImageMobile?: string;
}

const { title, description, active, path = '', ogTitle, ogDescription, preloadImage, preloadImageMobile } = Astro.props;
const canonical = new URL(path, Astro.site).href;
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <!-- Mark JS as available before paint so reveal elements can start hidden
         without ever hiding content from no-JS clients. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {preloadImage && preloadImageMobile ? (
      <Fragment>
        <link rel="preload" as="image" href={preloadImageMobile} media="(max-width: 820px)" fetchpriority="high" />
        <link rel="preload" as="image" href={preloadImage} media="(min-width: 821px)" fetchpriority="high" />
      </Fragment>
    ) : preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#27060f" />
    <!-- Fonts are self-hosted (declared in global.css). Preload Krona One, the
         hero display face that renders the LCP heading. Montserrat loads via
         font-display:swap on the same origin - no third-party handshake. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts.gstatic.com/s/kronaone/v15/jAnEgHdjHcjgfIb1ZcUCNI-h3cWkWg.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat/montserrat-var.woff2" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <link rel="canonical" href={canonical} />
  </head>
  <body>
    <Nav active={active} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>import '../scripts/nav.ts';</script>
    <script>import '../scripts/scroll-animations.ts';</script>
  </body>
</html>
