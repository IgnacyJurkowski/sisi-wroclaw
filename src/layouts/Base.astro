---
import '../styles/global.css';
import Logo from '../components/Logo.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import Particles from '../components/Particles.astro';
import { BUSINESS, nightClubSchema, websiteSchema } from '../data/site';
import { DEFAULT_LOCALE, LOCALE_LANG, LOCALE_OG, type Locale } from '../i18n/config';
import { alternates, localizedPath, type RouteKey } from '../i18n/routes';
import { jsonForHtml, robotsDirective } from '../lib/launch.mjs';

interface Props {
  locale: Locale;
  /** route identity - drives canonical, hreflang and the active nav item.
      Omitted for utility pages (404), which are noindexed. */
  routeKey?: RouteKey;
  /** explicit canonical/og:url path, overriding the routeKey-derived one
      (used by dynamic pages like event details). */
  path?: string;
  /** explicit hreflang alternates, overriding alternates(routeKey). */
  altPaths?: { locale: Locale; path: string }[];
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  /** above-the-fold hero image to preload (the LCP-area visual) */
  preloadImage?: string;
  /** social-share image; path is resolved against the site origin */
  ogImage?: string;
  /** keep the page out of the index (utility pages) */
  noindex?: boolean;
  /** extra page-level JSON-LD objects (e.g. Event list) rendered in <head> */
  schema?: Record<string, unknown>[];
}

const {
  locale,
  routeKey,
  path,
  altPaths,
  title,
  description,
  ogTitle,
  ogDescription,
  preloadImage,
  // Absolute Framer CDN URL so the social card resolves (HTTP 200) on every host,
  // including the deploy preview. The site-relative form 404s until sisiwroclaw.pl
  // points at this build, and the CDN serves this asset as .png (the local .webp
  // is a downscaled copy that only exists under this site's /public).
  // TODO(ignacy): replace with a self-hosted 1200x630 image in /public/og/ once
  // the production domain serves this build.
  ogImage = 'https://framerusercontent.com/images/nBW0AVejCOoiy2Rctqcid0SY6Q.png',
  noindex = false,
  schema = [],
} = Astro.props;

const canonicalPath = path ?? (routeKey ? localizedPath(routeKey, locale) : undefined);
const canonical = canonicalPath ? new URL(canonicalPath, Astro.site).href : undefined;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const altList = altPaths ?? (routeKey ? alternates(routeKey) : []);
const hreflangs = altList.map((a) => ({ locale: a.locale, href: new URL(a.path, Astro.site).href }));
const xDefaultPath = altPaths
  ? altPaths.find((a) => a.locale === DEFAULT_LOCALE)?.path
  : routeKey
    ? localizedPath(routeKey, DEFAULT_LOCALE)
    : undefined;
const xDefault = xDefaultPath ? new URL(xDefaultPath, Astro.site).href : undefined;
const jsonLd = [nightClubSchema(locale), websiteSchema(locale), ...schema];

const robotsContent = robotsDirective({
  context: process.env.CONTEXT,
  siteUrl: process.env.URL,
  canonicalOrigin: BUSINESS.url,
  noindex,
});
---

<!DOCTYPE html>
<html lang={LOCALE_LANG[locale]}>
  <head>
    <!-- Mark JS as available before paint so reveal elements can start hidden
         without ever hiding content from no-JS clients. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#27060f" />
    <!-- Fonts are self-hosted (declared in global.css). Preload Cal Sans (the
         LCP hero heading). Montserrat is inlined as a data URI in the CSS, so it
         needs no preload - it is present when the stylesheet parses. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/cal-sans-400-latin.woff2" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robotsContent && <meta name="robots" content={robotsContent} />}
    {canonical && <link rel="canonical" href={canonical} />}
    {hreflangs.map((h) => <link rel="alternate" hreflang={h.locale} href={h.href} />)}
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={LOCALE_OG[locale]} />
    {hreflangs.filter((h) => h.locale !== locale).map((h) => (
      <meta property="og:locale:alternate" content={LOCALE_OG[h.locale]} />
    ))}
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content="SiSi Wrocław" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogTitle ?? title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLd.map((value) => (
      <script type="application/ld+json" set:html={jsonForHtml(value)} />
    ))}
  </head>
  <body>
    {/* First-paint intro veil: a wine screen with the mark that lifts on load.
        Purely decorative and non-blocking (pointer-events off, fades to hidden
        via a forwards animation, removed entirely for reduced-motion), so it can
        never trap interaction the way the earlier storage-gated loader did. */}
    <div class="page-intro" aria-hidden="true"><span class="page-intro__mark"><Logo /></span></div>
    {/* Sits at 40px down the page; an IntersectionObserver toggles the nav's
        scrolled state when it leaves the viewport — no scroll listener reading
        window.scrollY (that read forces a layout flush -> "Forced reflow"). */}
    <div id="nav-sentinel" aria-hidden="true"></div>
    <Particles />
    <Nav locale={locale} active={routeKey} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <CookieBanner locale={locale} />
    <script>import '../scripts/nav.ts';</script>
    <script>import '../scripts/scroll-animations.ts';</script>
    {/* Wake the frozen Particles backdrop only after the page is visually
        complete (load + idle), so its continuous drift/twinkle never inflates
        mobile Speed Index. Honours prefers-reduced-motion (the field stays
        still); the CSS in Particles.astro guards this too. */}
    <script>
      (function () {
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var live = function () { document.documentElement.classList.add('bg-live'); };
        var idle = function () {
          if ('requestIdleCallback' in window) requestIdleCallback(live, { timeout: 2000 });
          else setTimeout(live, 200);
        };
        if (document.readyState === 'complete') idle();
        else window.addEventListener('load', idle, { once: true });
      })();
    </script>
  </body>
</html>
