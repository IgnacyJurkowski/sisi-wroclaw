---
/*
 * Particles — the site's living backdrop: a field of soft cream/gold circles
 * drifting up through the wine, like light motes or champagne bubbles in a dark
 * club. Pure CSS, no JS, no library (the classic box-shadow starfield, adapted
 * to SiSi's palette). It sits fixed behind everything (z-index:-1) and shows
 * through every transparent section below the hero, so the page never reads as
 * flat wine.
 *
 * The Sass `random()` loop from the reference is replaced by build-time
 * generation here: a seeded RNG scatters each layer's circles into one
 * box-shadow value, so the field is identical on every page and reproducible
 * build-to-build. Each rasterized layer animates two cheap, compositor-only
 * properties: a transform (the upward drift) and opacity (a staggered twinkle
 * that makes the field sparkle). A duplicate ::after offset by the tile height
 * loops the drift seamlessly.
 *
 * Reduced motion freezes both drift and sparkle (a still field is still lovely).
 */
type Rand = () => number;
function rng(seed: number): Rand {
  return function () {
    seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
function field(rand: Rand, n: number, W: number, H: number, colors: string[], blur = 0, spread = 0): string {
  const parts: string[] = [];
  for (let i = 0; i < n; i++) {
    const x = Math.floor(rand() * W);
    const y = Math.floor(rand() * H);
    const c = colors[Math.floor(rand() * colors.length)];
    parts.push(blur || spread ? `${x}px ${y}px ${blur}px ${spread}px ${c}` : `${x}px ${y}px ${c}`);
  }
  return parts.join(', ');
}

// Tile is 2000px tall; the ::after copy + keyframe both use this height to loop.
const W = 2560, H = 2000;
const r = rng(20260625);

const cream = ['rgba(237,219,194,0.85)', 'rgba(245,232,213,0.7)'];
const gold = ['rgba(251,210,149,0.7)', 'rgba(245,232,213,0.6)'];
const orbCol = ['rgba(251,210,149,0.20)', 'rgba(237,219,194,0.18)'];
const bigCol = ['rgba(245,232,213,0.13)', 'rgba(251,210,149,0.11)'];
const bright = ['rgba(255,250,242,0.95)', 'rgba(255,243,214,0.92)'];   // sparkle A
const brightG = ['rgba(255,238,205,0.95)', 'rgba(255,250,242,0.9)'];   // sparkle B

const sm = field(r, 200, W, H, cream);        // fine dust
const md = field(r, 90, W, H, gold);          // mid motes
const bgDots = field(r, 40, W, H, cream);     // larger sparse points
const orbs = field(r, 26, W, H, orbCol, 5, 1); // soft glowing circles
const lg = field(r, 14, W, H, bigCol, 10, 2);  // big soft bokeh
const spA = field(r, 26, W, H, bright);        // bright sparkles (fast twinkle)
const spB = field(r, 22, W, H, brightG);       // bright sparkles (offset phase)
const dn = field(r, 34, W, H, cream);          // sparse dots drifting downward

const vars = `--sm:${sm}; --md:${md}; --bg2:${bgDots}; --orb:${orbs}; --lg:${lg}; --spA:${spA}; --spB:${spB}; --dn:${dn}`;
---

<div class="circles" aria-hidden="true" style={vars}>
  <div class="cir lg"></div>
  <div class="cir orb"></div>
  <div class="cir bg"></div>
  <div class="cir md"></div>
  <div class="cir sm"></div>
  <div class="cir spA"></div>
  <div class="cir spB"></div>
  <div class="cir dn"></div>
</div>

<style>
  .circles {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
    /* a touch of depth: warm glow up top, pooled shadow at the floor */
    background:
      radial-gradient(ellipse 120% 80% at 50% 120%, rgba(61, 19, 32, 0.55) 0%, rgba(0, 0, 0, 0) 60%),
      radial-gradient(ellipse at 50% -10%, rgba(140, 36, 52, 0.18) 0%, rgba(0, 0, 0, 0) 45%),
      var(--bg);
  }
  /* Each layer is a tiny anchor carrying its circles in a single box-shadow;
     the ::after is the same field shifted one tile down for a seamless loop.
     floatUp drifts (transform), tw twinkles (opacity) — both compositor-only.
     --lo is each layer's dim point so big orbs pulse gently, sparks flicker hard. */
  .cir {
    position: absolute; top: 0; left: 0;
    border-radius: 50%; background: transparent;
    /* Field is frozen (static) on purpose. The continuous drift + twinkle kept
       the viewport pixels changing all through load, so the page never read as
       "visually complete" and mobile Speed Index ballooned (~4.2s → a 97 cap).
       A still field is still lovely — this is the same state reduced-motion got.
       Re-enabling motion means re-introducing that Speed Index cost. */
    animation: none !important;
  }
  .cir::after {
    content: ""; position: absolute; top: 2000px; left: 0;
    border-radius: 50%;
  }
  .cir.sm  { width: 2px;  height: 2px;  box-shadow: var(--sm);  --lo: 0.35; animation: floatUp 90s linear infinite, tw 7s ease-in-out infinite; }
  .cir.sm::after  { width: 2px;  height: 2px;  box-shadow: var(--sm); }
  .cir.md  { width: 3px;  height: 3px;  box-shadow: var(--md);  --lo: 0.4;  animation: floatUp 140s linear infinite, tw 9s ease-in-out infinite -3s; }
  .cir.md::after  { width: 3px;  height: 3px;  box-shadow: var(--md); }
  .cir.bg  { width: 4px;  height: 4px;  box-shadow: var(--bg2); --lo: 0.5;  animation: floatUp 200s linear infinite, tw 11s ease-in-out infinite -5s; }
  .cir.bg::after  { width: 4px;  height: 4px;  box-shadow: var(--bg2); }
  .cir.orb { width: 12px; height: 12px; box-shadow: var(--orb); filter: blur(0.5px); --lo: 0.6;  animation: floatUp 240s linear infinite, tw 15s ease-in-out infinite; }
  .cir.orb::after { width: 12px; height: 12px; box-shadow: var(--orb); }
  .cir.lg  { width: 20px; height: 20px; box-shadow: var(--lg); filter: blur(1px);  --lo: 0.65; animation: floatUp 320s linear infinite, tw 19s ease-in-out infinite -4s; }
  .cir.lg::after  { width: 20px; height: 20px; box-shadow: var(--lg); }
  .cir.spA { width: 2px;  height: 2px;  box-shadow: var(--spA); --lo: 0.1;  animation: floatUp 70s linear infinite, tw 3.2s ease-in-out infinite; }
  .cir.spA::after { width: 2px;  height: 2px;  box-shadow: var(--spA); }
  .cir.spB { width: 2px;  height: 2px;  box-shadow: var(--spB); --lo: 0.12; animation: floatUp 82s linear infinite, tw 4.6s ease-in-out infinite -1.6s; }
  .cir.spB::after { width: 2px;  height: 2px;  box-shadow: var(--spB); }
  /* A few dots drifting the other way (downward), for a little cross-current.
     The ::after copy sits one tile ABOVE so the downward loop is seamless. */
  .cir.dn  { width: 2px;  height: 2px;  box-shadow: var(--dn);  --lo: 0.3;  animation: floatDown 130s linear infinite, tw 8s ease-in-out infinite -2s; }
  .cir.dn::after  { top: -2000px; width: 2px;  height: 2px;  box-shadow: var(--dn); }

  @keyframes floatUp {
    from { transform: translateY(0); }
    to   { transform: translateY(-2000px); }
  }
  @keyframes floatDown {
    from { transform: translateY(0); }
    to   { transform: translateY(2000px); }
  }
  @keyframes tw {
    0%, 100% { opacity: var(--lo, 0.3); }
    50%      { opacity: 1; }
  }
</style>
