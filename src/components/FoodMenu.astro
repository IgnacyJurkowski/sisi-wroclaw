---
// The Cork kitchen menu — a full-bleed cream band at the very bottom of the menu
// page, colour-inverted from the dark bar cards above (burgundy ink on cream) to
// signal "this is the restaurant, not the bar". Fully localised in all 5 langs;
// dish data lives here (like WINES in MenuPage) rather than in the UI dictionaries,
// since it's a self-contained block of prose.
import { type Locale } from '../i18n/config';
interface Props { locale: Locale }
const { locale } = Astro.props;

type L = Record<Locale, string>;
type Diet = 'vegetarian' | 'vegan';
interface Tier { qty?: L; price: string }
interface Dish { icon: string; name: L; desc?: L; tiers: Tier[]; diet?: Diet }
interface FoodSection { title: L; icon: string; dishes: Dish[] }

