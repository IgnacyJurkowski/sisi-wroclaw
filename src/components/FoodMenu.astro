---

<section class="food-menu" data-reveal-group>
  <div class="food-inner">
    <header class="food-head" data-reveal>
      <span class="food-eyebrow">{TAGLINE.eyebrow}</span>
      <h2 class="food-title display">{TAGLINE.heading[locale]}</h2>
      <p class="food-sub">{TAGLINE.sub[locale]}</p>
    </header>

    <div class="food-grid">
      {SECTIONS.map((sec) => (
        <div class="food-col" data-reveal>
          <h3 class="food-section-label">{sec.title[locale]}</h3>
          {sec.dishes.map((d) => (
            <article class="food-item">
              <div class="food-item-head">
                <h4 class="food-name">{d.name[locale]}</h4>
                <div class="food-prices">
                  {d.tiers.map((tr) => (
                    <span class="food-price">
                      {tr.qty && <span class="food-qty">{tr.qty[locale]}</span>}{tr.price}
                    </span>
                  ))}
                </div>
              </div>
              {d.desc && <p class="food-desc">{d.desc[locale]}</p>}
            </article>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Full-bleed cream band, colour-inverted from the dark bar cards. Sits above
     the fixed particle backdrop (opaque cream covers it in this band). */
  .food-menu {
    position: relative; z-index: 1;
    background: var(--cream);
    color: #27060f;
    margin-top: 96px;
    padding: 96px 32px 104px;
  }
  .food-inner { max-width: var(--maxw); margin: 0 auto; }

  .food-head { text-align: center; max-width: 640px; margin: 0 auto 64px; }
  .food-eyebrow {
    display: inline-block; font-size: 12px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.18em;
    color: rgba(39, 7, 15, 0.55); margin-bottom: 18px;
  }
  .food-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem); line-height: 1.05;
    text-transform: uppercase; letter-spacing: -0.01em;
    color: #27060f; margin: 0 0 18px;
  }
  .food-sub { font-size: 15px; line-height: 1.7; color: rgba(39, 7, 15, 0.62); margin: 0; }

  .food-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 24px 56px;
    max-width: 980px; margin: 0 auto; align-items: start;
  }
  .food-section-label {
    font-family: var(--font-display); font-size: 1.35rem; font-weight: 400;
    text-transform: uppercase; letter-spacing: 0.05em; color: #27060f;
    margin: 0 0 6px; padding-bottom: 14px;
    border-bottom: 1px solid rgba(39, 7, 15, 0.18);
  }
  .food-item { padding: 18px 0; border-bottom: 1px solid rgba(39, 7, 15, 0.1); }
  .food-item:last-child { border-bottom: none; }
  .food-item-head { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; }
  .food-name { font-size: 16px; font-weight: 700; letter-spacing: 0.01em; color: #27060f; margin: 0; }
  .food-prices { flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-end; gap: 2px; text-align: right; }
  .food-price { font-size: 14px; font-weight: 600; color: #27060f; white-space: nowrap; }
  .food-qty { font-size: 11px; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: rgba(39, 7, 15, 0.5); margin-right: 8px; }
  .food-desc { font-size: 13px; line-height: 1.6; color: rgba(39, 7, 15, 0.62); margin: 6px 0 0; max-width: 46ch; }

  @media (max-width: 760px) {
    .food-menu { margin-top: 72px; padding: 72px 20px 80px; }
    .food-grid { grid-template-columns: 1fr; gap: 8px; }
    .food-head { margin-bottom: 48px; }
  }
</style>
