---
import Base from '../../layouts/Base.astro';
import EventCard from '../EventCard.astro';
import { splitEvents, eventSchema } from '../../data/site';
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

const { upcoming, past } = splitEvents();
const archive = past.slice(0, 8);
---

<Base
  locale={locale}
  routeKey="events"
  title={t.meta.events.title}
  description={t.meta.events.description}
  ogDescription={t.meta.events.ogDescription}
  schema={eventSchema(upcoming, locale)}
>
  <div class="page-header" data-reveal>
    <span class="page-label">{t.eventsPage.label}</span>
    <h1 class="page-title display">{t.eventsPage.title}</h1>
    <p class="page-subtitle">{t.eventsPage.subtitle}</p>
  </div>

  <section class="ev-section" data-reveal>
    <h2 class="display ev-row-title">{t.eventsPage.upcoming}</h2>
    {upcoming.length > 0 ? (
      <ul class="ev-list">
        {upcoming.map((e) => (
          <li><EventCard event={e} locale={locale} /></li>
        ))}
      </ul>
    ) : (
      <p class="ev-empty">{t.eventsPage.empty}</p>
    )}
  </section>

  {past.length > 0 && (
    <section class="ev-section archive" data-reveal>
      <h2 class="display ev-row-title">{t.eventsPage.archive}</h2>
      <ul class="ev-list">
        {archive.map((e) => (
          <li><EventCard event={e} locale={locale} past /></li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  .ev-section {
    max-width: var(--maxw);
    margin: 0 auto 72px;
    padding-inline: 20px;
  }
  .ev-section:last-of-type { margin-bottom: 96px; }
  .ev-row-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .ev-list {
    display: flex; flex-direction: column; gap: 20px;
    list-style: none; margin: 0; padding: 0;
  }
  .ev-empty { color: var(--text-dim); font-size: 16px; }
</style>
