---
import Base from '../../layouts/Base.astro';
import Reservations from '../home/Reservations.astro';
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<Base
  locale={locale}
  routeKey="reservations"
  title={t.meta.reservations.title}
  description={t.meta.reservations.description}
  ogTitle={t.meta.reservations.title}
  ogDescription={t.meta.reservations.ogDescription}
>
  <div class="res-page">
    <Reservations locale={locale} headingLevel="h1" showLocaleFallback />

    <section class="res-details" data-reveal>
      <div class="res-details-grid">
        <article class="sisi-card res-details-card" data-reservation-section="practical">
          <h2 class="menu-section-label">{t.reservationsPage.practicalTitle}</h2>
          <ul class="res-terms-list">
            {t.reservationsPage.practicalConditions.map((c) => <li>{c}</li>)}
          </ul>
        </article>

        <article class="sisi-card res-details-card" data-reservation-section="terms">
          <h2 class="menu-section-label">{t.reservationsPage.conditionsTitle}</h2>
          <ul class="res-terms-list">
            {t.reservationsPage.conditions.map((c) => <li>{c}</li>)}
          </ul>
          <p class="res-terms-note">{t.reservationsPage.note}</p>
        </article>
      </div>
    </section>
  </div>
</Base>

<style>
  .res-page { padding-top: calc(var(--nav-height) - 12px); }
  .res-details { max-width: 1040px; margin: 0 auto 96px; padding: 0 32px; }
  .res-details-grid {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px; align-items: stretch;
  }
  .res-details-card { min-width: 0; padding: 32px 36px; }
  .res-details-card .menu-section-label { min-width: 0; overflow-wrap: anywhere; }
  .res-terms-list {
    margin: 18px 0 0; padding: 0; list-style: none;
    display: flex; flex-direction: column; gap: 12px;
  }
  .res-terms-list li {
    position: relative; padding-left: 22px;
    font-size: 14px; line-height: 1.7; color: var(--text-dim);
  }
  .res-terms-list li::before {
    content: ''; position: absolute; left: 4px; top: 10px;
    width: 6px; height: 6px; border-radius: 50%; background: var(--gold);
  }
  .res-terms-note {
    margin-top: 22px; padding-top: 18px; border-top: 1px solid var(--line);
    font-size: 13px; line-height: 1.7; color: var(--text-faint);
  }
  @media (max-width: 820px) {
    .res-details-grid { grid-template-columns: 1fr; max-width: 520px; margin: 0 auto; }
  }
  @media (max-width: 600px) {
    .res-details { padding-inline: 20px; }
    .res-details-card { padding: 28px 24px; }
  }
</style>
