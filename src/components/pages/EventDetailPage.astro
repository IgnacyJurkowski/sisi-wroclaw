---
import Base from '../../layouts/Base.astro';
import { reservationUrl, eventSchema, EVENT_DURATION_MS, type EventItem } from '../../data/site';
import { type Locale } from '../../i18n/config';
import { localizedPath, eventPath, eventAlternates } from '../../i18n/routes';
import { formatEventDate, dateTimeAttr } from '../../i18n/format';
import { useTranslations } from '../../i18n/t';

interface Props {
  locale: Locale;
  event: EventItem;
}
const { locale, event } = Astro.props;
const t = useTranslations(locale);

const past = new Date(event.start).getTime() + EVENT_DURATION_MS < Date.now();
const metaTitle = `${event.title} | SiSi Wrocław`;
const metaDesc = event.description || t.meta.events.description;
---

<Base
  locale={locale}
  routeKey="events"
  path={eventPath(event.slug, locale)}
  altPaths={eventAlternates(event.slug)}
  title={metaTitle}
  description={metaDesc}
  ogTitle={event.title}
  ogDescription={metaDesc}
  ogImage={event.img}
  preloadImage={event.img}
  schema={eventSchema([event], locale)}
>
  <article class="evd">
    <a class="evd-back" href={localizedPath('events', locale)} data-reveal>
      <span aria-hidden="true">←</span> {t.eventsPage.back}
    </a>

    <div class="evd-hero" data-reveal>
      <img src={event.img} alt={event.title} fetchpriority="high" />
    </div>

    <div class="evd-body" data-reveal>
      <h1 class="display evd-title">{event.title}</h1>
      {event.note && <p class="evd-dj">{event.note}</p>}

      {event.genres && event.genres.length > 0 && (
        <ul class="evd-genres">{event.genres.map((g) => <li>{g}</li>)}</ul>
      )}

      <p class="evd-date">
        <time datetime={dateTimeAttr(event.start)}>{formatEventDate(event.start, locale)}</time>
      </p>

      {event.description && <p class="evd-desc">{event.description}</p>}

      <div class="evd-foot">
        {event.price != null && (
          <span class="evd-price">
            {event.price === 0 ? t.eventCard.freeEntry : `${t.eventCard.entry} ${event.price} zł`}
          </span>
        )}
        {past ? (
          <span class="evd-done">{t.eventCard.finished}</span>
        ) : (
          <a href={reservationUrl('event_detail')} class="btn-cta" rel="noopener" target="_blank">
            {t.eventCard.reserve}
          </a>
        )}
      </div>
    </div>
  </article>
</Base>

<style>
  .evd {
    max-width: 920px;
    margin: 0 auto;
    padding: clamp(20px, 5vw, 48px) 20px 96px;
  }
  .evd-back {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--text-dim); text-decoration: none; margin-bottom: 28px;
    transition: color 200ms ease;
  }
  .evd-back:hover { color: var(--cream); }
  .evd-hero {
    aspect-ratio: 16 / 9; overflow: hidden; border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08); background: var(--panel);
  }
  .evd-hero img { width: 100%; height: 100%; object-fit: cover; }
  .evd-body { margin-top: 36px; }
  .evd-title {
    font-size: clamp(2rem, 6vw, 3.4rem); text-transform: uppercase; line-height: 1.05;
  }
  .evd-dj {
    margin-top: 10px; font-size: 15px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--cream);
  }
  .evd-genres {
    display: flex; flex-wrap: wrap; gap: 8px; list-style: none; padding: 0;
    margin: 18px 0 0;
  }
  .evd-genres li {
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-mute); border: 1px solid var(--line);
    padding: 5px 12px; border-radius: 99px;
  }
  .evd-date {
    margin-top: 18px; font-size: 16px; color: rgba(237, 219, 194, 0.7);
  }
  .evd-desc {
    margin-top: 22px; font-size: 16px; line-height: 1.7; color: var(--text-dim);
    max-width: 62ch; white-space: pre-line;
    /* glass panel so the event description reads as frosted over the circles
       (backdrop-filter unprefixed; Lightning CSS adds -webkit-). */
    background: rgba(39, 7, 15, 0.42);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(237, 219, 194, 0.18);
    border-radius: 14px;
    padding: 22px 26px;
  }
  .evd-foot {
    display: flex; align-items: center; flex-wrap: wrap; gap: 20px;
    margin-top: 36px;
  }
  .evd-price {
    font-size: 14px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--gold);
  }
  .evd-done {
    font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-mute); border: 1px solid var(--line);
    padding: 11px 20px; border-radius: 10px;
  }
</style>
