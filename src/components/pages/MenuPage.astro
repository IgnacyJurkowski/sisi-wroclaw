---
import Base from '../../layouts/Base.astro';
import MenuItem from '../MenuItem.astro';
import { reservationUrl } from '../../data/site';
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

// Cocktail and spirit brand names stay as-is (Hugo Spritz, Chivas XII, …); the
// generic ingredient words and beer-style descriptors are localized so non-Polish
// guests can read what's in each drink. Brand tokens simply fall through unchanged.
// Cocktail ingredients are keyed by their Polish source word, so `pl` is omitted
// (the source text is already Polish). Beer styles are keyed by their English
// source text, so they carry an explicit `pl` value too.
type Item = { name: string; desc?: string; vol?: string; price: string };

const INGREDIENTS: Record<string, Partial<Record<Locale, string>>> = {
  'Limonka': { en: 'Lime', de: 'Limette', it: 'Lime', cs: 'Limetka' },
  'Mięta': { en: 'Mint', de: 'Minze', it: 'Menta', cs: 'Máta' },
  'Woda gazowana': { en: 'Sparkling water', de: 'Sodawasser', it: 'Acqua frizzante', cs: 'Sodová voda' },
  'Pomarańcze': { en: 'Oranges', de: 'Orangen', it: 'Arance', cs: 'Pomeranče' },
  'Marakuja': { en: 'Passion fruit', de: 'Maracuja', it: 'Frutto della passione', cs: 'Marakuja' },
  'Wanilia': { en: 'Vanilla', de: 'Vanille', it: 'Vaniglia', cs: 'Vanilka' },
  'Cytryna': { en: 'Lemon', de: 'Zitrone', it: 'Limone', cs: 'Citron' },
  'Cukier': { en: 'Sugar', de: 'Zucker', it: 'Zucchero', cs: 'Cukr' },
  'Egg White': { en: 'Egg white', de: 'Eiweiß', it: 'Albume', cs: 'Bílek' },
  'Olejki pomarańczy': { en: 'Orange oils', de: 'Orangenöl', it: "Oli d'arancia", cs: 'Pomerančový olej' },
  'Skórka pomarańczy': { en: 'Orange peel', de: 'Orangenschale', it: "Scorza d'arancia", cs: 'Pomerančová kůra' },
  'Cytrusy': { en: 'Citrus', de: 'Zitrusfrüchte', it: 'Agrumi', cs: 'Citrusy' },
  'Czerwony wermut': { en: 'Red vermouth', de: 'Roter Wermut', it: 'Vermouth rosso', cs: 'Červený vermut' },
  'Woda mineralna niegazowana': { en: 'Still mineral water', de: 'Stilles Mineralwasser', it: 'Acqua minerale naturale', cs: 'Neperlivá minerální voda' },
  'Woda mineralna gazowana': { en: 'Sparkling mineral water', de: 'Mineralwasser mit Kohlensäure', it: 'Acqua minerale frizzante', cs: 'Perlivá minerální voda' },
  'Brzoskwinia': { en: 'Peach', de: 'Pfirsich', it: 'Pesca', cs: 'Broskev' },
  'Hibiskus': { en: 'Hibiscus', de: 'Hibiskus', it: 'Ibisco', cs: 'Ibišek' },
  'Multiwitamina': { en: 'Multivitamin', de: 'Multivitamin', it: 'Multivitaminico', cs: 'Multivitamin' },
  'Grejpfrut': { en: 'Grapefruit', de: 'Grapefruit', it: 'Pompelmo', cs: 'Grapefruit' },
  // Beer styles (source text is English; ABV and Blonde/Brune variant names stay).
  'Belgian lager': { pl: 'lager belgijski', en: 'Belgian lager', de: 'belgisches Lager', it: 'lager belga', cs: 'belgický ležák' },
  'Belgian wheat ale': { pl: 'belgijskie piwo pszeniczne', en: 'Belgian wheat ale', de: 'belgisches Weißbier', it: 'birra di frumento belga', cs: 'belgické pšeničné pivo' },
  'Belgian blonde ale': { pl: 'belgijski jasny ale', en: 'Belgian blonde ale', de: 'belgisches Blond Ale', it: 'blonde ale belga', cs: 'belgický světlý ale' },
  'Belgian ale': { pl: 'ale belgijski', en: 'Belgian ale', de: 'belgisches Ale', it: 'ale belga', cs: 'belgický ale' },
  'Mexican lager': { pl: 'lager meksykański', en: 'Mexican lager', de: 'mexikanisches Lager', it: 'lager messicano', cs: 'mexický ležák' },
  'German lager': { pl: 'lager niemiecki', en: 'German lager', de: 'deutsches Lager', it: 'lager tedesco', cs: 'německý ležák' },
  'American lager': { pl: 'lager amerykański', en: 'American lager', de: 'amerikanisches Lager', it: 'lager americano', cs: 'americký ležák' },
};

// Localize each generic token, keeping brand tokens, ABV and volumes as-is. Descs
// use " / " between ingredients and " · " between a beer style and its ABV; split
// on both so each token can be looked up. Polish (and any token absent from the
// glossary) keeps the original word.
function localizeDesc(desc: string, loc: Locale): string {
  return desc
    .split(' · ')
    .map((part) =>
      part
        .split(' / ')
        .map((tok) => INGREDIENTS[tok.trim()]?.[loc] ?? tok.trim())
        .join(' / '),
    )
    .join(' · ');
}

// Polish-vineyard wine list, grouped by colour. Wine name, winery, grape names
// and region are brand/proper-noun invariant; dryness and the colour category
// are localised (DRYNESS / WINE_CATEGORIES). Prices are per-wine: a 125 ml glass
// and a 750 ml bottle. `vintage` is only set where a year was given; `featured`
// flags the one premium pour (a subtle label, never a loud badge).
type WineCategory = 'white' | 'red' | 'roseOrange';
type Dryness = 'dry' | 'semiDry';

interface Wine {
  category: WineCategory;
  name: string;
  winery: string;
  dryness?: Dryness;
  grapes?: string[];
  region?: string;
  glassPrice: string;   // 125 ml
  bottlePrice: string;  // 750 ml
  vintage?: string;
  featured?: boolean;
}

const WINES: Wine[] = [
  // White
  { category: 'white', name: 'Halka', winery: "Winnica L'Opera", dryness: 'semiDry', grapes: ['Chardonnay', 'Bronner', 'Muscaris'], region: 'Wzgórza Trzebnickie, Dolny Śląsk', glassPrice: '32 zł', bottlePrice: '190 zł' },
  { category: 'white', name: 'Hibernal', winery: 'Winnica Turnau', dryness: 'semiDry', grapes: ['Hibernal'], region: 'Baniewice, Pomorze Zachodnie', glassPrice: '55 zł', bottlePrice: '330 zł' },
  { category: 'white', name: 'Solaris', winery: 'Dom Charbielin', dryness: 'semiDry', grapes: ['Solaris'], region: 'Charbielin, Opolskie', glassPrice: '60 zł', bottlePrice: '360 zł' },
  { category: 'white', name: 'Chardonnay Barrique', winery: 'Winnica Płochockich', dryness: 'dry', grapes: ['Chardonnay'], region: 'Daromin, Świętokrzyskie', glassPrice: '70 zł', bottlePrice: '420 zł', vintage: '2024', featured: true },
  // Red
  { category: 'red', name: 'Triada', winery: "Winnica L'Opera", dryness: 'dry', grapes: ['Baron', 'Cabernet Cantor', 'Cabernet Cortis'], region: 'Wzgórza Trzebnickie, Dolny Śląsk', glassPrice: '32 zł', bottlePrice: '190 zł' },
  { category: 'red', name: 'Rege', winery: 'Winnica Płochockich', glassPrice: '55 zł', bottlePrice: '330 zł' },
  { category: 'red', name: 'Pinot Noir', winery: 'Winnica Turnau', dryness: 'dry', grapes: ['Pinot Noir'], region: 'Baniewice, Pomorze Zachodnie', glassPrice: '70 zł', bottlePrice: '420 zł' },
  // Rosé / Orange
  { category: 'roseOrange', name: 'Yacobus Orange', winery: 'Winnica Jakubów', dryness: 'dry', grapes: ['Hibernal', 'Riesling', 'Solaris', 'Traminer'], region: 'Wzgórza Dalkowskie, Dolny Śląsk', glassPrice: '65 zł', bottlePrice: '390 zł' },
  { category: 'roseOrange', name: 'Rosé', winery: 'Winnica Turnau', dryness: 'semiDry', grapes: ['Rondo', 'Regent'], region: 'Baniewice, Pomorze Zachodnie', glassPrice: '55 zł', bottlePrice: '330 zł' },
];

// Display order of the colour groups + their localised labels.
const WINE_CATEGORIES: { key: WineCategory; label: Record<Locale, string> }[] = [
  { key: 'white',      label: { pl: 'Białe', en: 'White', de: 'Weiß', it: 'Bianco', cs: 'Bílé' } },
  { key: 'red',        label: { pl: 'Czerwone', en: 'Red', de: 'Rot', it: 'Rosso', cs: 'Červené' } },
  { key: 'roseOrange', label: { pl: 'Różowe / Pomarańczowe', en: 'Rosé / Orange', de: 'Rosé / Orange', it: 'Rosato / Arancione', cs: 'Růžové / Oranžové' } },
];

const DRYNESS: Record<Dryness, Record<Locale, string>> = {
  dry: { pl: 'wytrawne', en: 'dry', de: 'trocken', it: 'secco', cs: 'suché' },
  semiDry: { pl: 'półwytrawne', en: 'semi-dry', de: 'halbtrocken', it: 'semisecco', cs: 'polosuché' },
};

const FEATURED_LABEL: Record<Locale, string> = {
  pl: 'Polecamy', en: 'Recommended', de: 'Empfehlung', it: 'Consigliato', cs: 'Doporučujeme',
};

// Champagne (Maison Mumm + Perrier-Jouët), grouped by house. Each cuvée carries
// up to four sizes (125 ml glass, 750 ml, 1.5 l magnum, 3 l jeroboam); null =
// not offered in that size. Only Grand Cordon and Grand Brut are poured by the
// glass (see champagneNote). Brand names and prices are invariant, not localised.
const CHAMP_VOLS = ['125 ml', '750 ml', '1,5 l', '3 l'] as const;

interface Champagne { name: string; prices: (string | null)[] }
const CHAMPAGNE_HOUSES: { house: string; items: Champagne[] }[] = [
  {
    house: 'G. H. Mumm',
    items: [
      { name: 'Grand Cordon', prices: ['65 zł', '390 zł', '900 zł', '2300 zł'] },
      { name: 'Grand Cordon Rosé', prices: [null, '450 zł', '950 zł', null] },
      { name: 'Demi Sec', prices: [null, '450 zł', null, null] },
      { name: 'Ice Xtra', prices: [null, '450 zł', null, null] },
    ],
  },
  {
    house: 'Perrier-Jouët',
    items: [
      { name: 'Grand Brut', prices: ['90 zł', '550 zł', '1500 zł', '4500 zł'] },
      { name: 'Blason Rosé', prices: [null, '650 zł', null, null] },
      { name: 'Blanc de Blancs', prices: [null, '700 zł', null, null] },
      { name: 'Belle Époque Brut 2015', prices: [null, '1700 zł', null, null] },
    ],
  },
];

const koktajle: Item[] = [
  { name: 'Hugo Spritz', desc: 'St-Germain / Limonka / Mięta / Martini Prosecco / Woda gazowana', vol: '160 ml', price: '40 zł' },
  { name: 'Fiero Spritz', desc: 'Martini Fiero / Martini Prosecco / Pomarańcze / Woda gazowana', vol: '180 ml', price: '39 zł' },
  { name: 'Porn Star Martini', desc: 'Ostoya / Marakuja / Wanilia / Martini Prosecco', vol: '120 ml', price: '40 zł' },
  { name: 'Whisky Sour', desc: 'Chivas XII / Cytryna / Cukier / Egg White / Angostura Bitters / Olejki pomarańczy', vol: '130 ml', price: '38 zł' },
  { name: 'Old Fashioned', desc: 'Chivas XII / Cukier / Angostura Bitters / Skórka pomarańczy', vol: '80 ml', price: '36 zł' },
  { name: 'Daiquiri', desc: 'Havana 7 / Limonka / Cukier', vol: '120 ml', price: '36 zł' },
  { name: 'Cuba Libre', desc: 'Havana 7 / Limonka / Coca-Cola', vol: '200 ml', price: '36 zł' },
  { name: 'Gin Tonic', desc: 'Beefeater 24 / 3 Cents Tonic / Cytrusy', vol: '200 ml', price: '36 zł' },
  { name: 'Negroni', desc: 'Beefeater 24 / Czerwony wermut / Martini Bitter / Skórka pomarańczy', vol: '120 ml', price: '38 zł' },
  { name: 'Long Island Iced Tea', desc: 'Ostoya / Beefeater 24 / Havana 3 / Olmeca Silver / Triple Sec / Coca-Cola / Limonka', vol: '180 ml', price: '48 zł' },
];

const napoje: Item[] = [
  { name: 'Coca-Cola Zero / Coca-Cola Original', vol: '250 ml', price: '12 zł' },
  { name: 'Sprite / Fanta', vol: '250 ml', price: '12 zł' },
  { name: 'Kropla Beskidu', desc: 'Woda mineralna niegazowana', vol: '330 ml', price: '10 zł' },
  { name: 'Délice by Kropla', desc: 'Woda mineralna gazowana', vol: '330 ml', price: '10 zł' },
  { name: 'Fuze Tea', desc: 'Cytryna / Brzoskwinia / Hibiskus', vol: '500 ml', price: '14 zł' },
  { name: 'Cappy', desc: 'Multiwitamina / Grejpfrut', vol: '330 ml', price: '12 zł' },
  { name: 'Red Bull Energy Drink', price: '16 zł' },
  { name: 'Red Bull Sugar Free', price: '16 zł' },
  { name: 'Red Bull Tropical Edition', price: '16 zł' },
];

const piwoLane: Item[] = [
  { name: 'Stella Artois', desc: 'Belgian lager · 5%', vol: '330 / 500 ml', price: '20 / 22 zł' },
  { name: 'Hoegaarden', desc: 'Belgian wheat ale · 4.9%', vol: '330 / 500 ml', price: '20 / 25 zł' },
  { name: 'Leffe', desc: 'Belgian blonde ale · 6.5%', vol: '330 / 500 ml', price: '24 / 33 zł' },
];

const piwoButelkowe: Item[] = [
  { name: 'Corona', desc: 'Mexican lager · 4.5%', price: '20 zł' },
  { name: 'Corona Cero', desc: 'Mexican lager · 0%', price: '20 zł' },
  { name: 'Leffe', desc: 'Belgian ale · Blonde 6.6% / Brune 6.5%', price: '22 zł' },
  { name: "Beck's", desc: 'German lager · 5%', price: '20 zł' },
  { name: 'Bud', desc: 'American lager · 5%', price: '20 zł' },
];

// Section-header icons (Lucide, MIT). Stroke glyphs rendered in --gold next to
// the Cal Sans label; the inner paths are injected with set:html into one <svg>.
const ICONS: Record<string, string> = {
  martini: '<path d="M8 22h8"/><path d="M12 11v11"/><path d="m19 3-7 8-7-8Z"/>',
  glass: '<path d="M5.116 4.104A1 1 0 0 1 6.11 3h11.78a1 1 0 0 1 .994 1.105L17.19 18.21A2 2 0 0 1 15.2 20H8.8a2 2 0 0 1-2-1.79z"/><path d="M6 12a5 5 0 0 1 6 0 5 5 0 0 0 6 0"/>',
  beer: '<path d="M17 11h1a3 3 0 0 1 0 6h-1"/><path d="M9 12v6"/><path d="M13 12v6"/><path d="M14 7.5c-1 0-1.44.5-3 .5s-2-.5-3-.5-1.72.5-2.5.5a2.5 2.5 0 0 1 0-5c.78 0 1.57.5 2.5.5S9.44 3 11 3s2 .5 3 .5 1.72-.5 2.5-.5a2.5 2.5 0 0 1 0 5c-.78 0-1.5-.5-2.5-.5Z"/><path d="M5 8v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8"/>',
  wine: '<path d="M8 22h8"/><path d="M7 10h10"/><path d="M12 15v7"/><path d="M12 15a5 5 0 0 0 5-5c0-2-.5-4-2-8H9c-1.5 4-2 6-2 8a5 5 0 0 0 5 5Z"/>',
  champagne: '<path d="M9 3h6l-.6 7.6a2.4 2.4 0 0 1-4.8 0z"/><path d="M12 13v6"/><path d="M9 21h6"/>',
  utensils: '<path d="M3 2v7c0 1.1.9 2 2 2h.5c1.1 0 2-.9 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>',
};
---

<Base
  locale={locale}
  routeKey="menu"
  title={t.meta.menu.title}
  description={t.meta.menu.description}
  ogDescription={t.meta.menu.ogDescription}
>
  <div class="page-header" data-reveal>
    <span class="page-label">{t.menuPage.label}</span>
    <h1 class="page-title display">{t.menuPage.title}</h1>
    <p class="page-subtitle">{t.menuPage.subtitle}</p>
  </div>

  {/* TODO(ignacy): wines now show by-glass/bottle prices; still need the Night
      Menu items and allergens. Until those land, the home CTA stays "bar menu"
      (seeFullMenu), not "full menu". */}
  <div class="menu-wrap">
    <div class="menu-grid" data-reveal-group>
      {/* LEFT: cocktails, champagne, night menu */}
      <div class="menu-stack">
        <section class="sisi-card menu-card">
          <h2 class="menu-section-label"><svg viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS.martini} />{t.menuPage.sections.cocktails}</h2>
          {koktajle.map((item) => (
            <MenuItem name={item.name} desc={item.desc ? localizeDesc(item.desc, locale) : undefined} vol={item.vol} price={item.price} />
          ))}
        </section>

        <section class="sisi-card menu-card">
          <h2 class="menu-section-label"><svg viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS.champagne} />{t.menuPage.sections.champagne}</h2>
          {CHAMPAGNE_HOUSES.map((h) => (
            <Fragment>
              <p class="menu-subsection">{h.house}</p>
              {h.items.map((c) => (
                <div class="champ-item">
                  <p class="champ-name">{c.name}</p>
                  <p class="champ-prices">{c.prices.map((p, i) => (p ? `${CHAMP_VOLS[i]} ${p}` : null)).filter(Boolean).join(' · ')}</p>
                </div>
              ))}
            </Fragment>
          ))}
          <p class="menu-note">{t.menuPage.champagneNote}</p>
        </section>

        <section class="sisi-card menu-card">
          <h2 class="menu-section-label"><svg viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS.utensils} />{t.menuPage.sections.nightMenu}</h2>
          <p class="fw-lead">{t.menuPage.nightLead}</p>
          <p class="menu-note">{t.menuPage.foodwineNote}</p>
        </section>
      </div>

      {/* RIGHT: wine, soft drinks, beer */}
      <div class="menu-stack">
        <section class="sisi-card menu-card">
          <h2 class="menu-section-label"><svg viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS.wine} />{t.menuPage.sections.wines}</h2>
          <p class="fw-lead">{t.menuPage.wineLead}</p>
          <div class="ptable ptable-2">
            <div class="ptable-head" aria-hidden="true">
              <span></span>
              <span class="pcol">125 ml</span>
              <span class="pcol">750 ml</span>
            </div>
            {WINE_CATEGORIES.map((cat) => {
              const list = WINES.filter((w) => w.category === cat.key);
              return list.length === 0 ? null : (
                <Fragment>
                  <p class="menu-subsection">{cat.label[locale]}</p>
                  {list.map((w) => (
                    <div class="prow wine-row">
                      <div class="wine-info">
                        <p class="wine-name">{w.name}{w.vintage ? ` ${w.vintage}` : ''}<span class="wine-winery"> — {w.winery}</span>{w.featured && <span class="wine-featured">{FEATURED_LABEL[locale]}</span>}</p>
                        {(w.dryness || w.grapes) && <p class="wine-meta">{[w.dryness && DRYNESS[w.dryness][locale], w.grapes?.join(', ')].filter(Boolean).join(' · ')}</p>}
                        {w.region && <p class="wine-region">{w.region}</p>}
                      </div>
                      <div class="prices">
                        <span class="pcell" data-vol="125 ml">{w.glassPrice}</span>
                        <span class="pcell" data-vol="750 ml">{w.bottlePrice}</span>
                      </div>
                    </div>
                  ))}
                </Fragment>
              );
            })}
          </div>
        </section>

        <section class="sisi-card menu-card">
          <h2 class="menu-section-label"><svg viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS.glass} />{t.menuPage.sections.drinks}</h2>
          {napoje.map((item) => (
            <MenuItem name={item.name} desc={item.desc ? localizeDesc(item.desc, locale) : undefined} vol={item.vol} price={item.price} />
          ))}
        </section>

        <section class="sisi-card menu-card">
          <h2 class="menu-section-label"><svg viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS.beer} />{t.menuPage.sections.beer}</h2>
          <p class="menu-subsection">{t.menuPage.sections.draught}</p>
          {piwoLane.map((item) => (
            <MenuItem name={item.name} desc={item.desc ? localizeDesc(item.desc, locale) : undefined} vol={item.vol} price={item.price} />
          ))}
          <p class="menu-subsection">{t.menuPage.sections.bottled}</p>
          {piwoButelkowe.map((item) => (
            <MenuItem name={item.name} desc={item.desc ? localizeDesc(item.desc, locale) : undefined} vol={item.vol} price={item.price} />
          ))}
          <p class="menu-note">{t.menuPage.bottledNote}</p>
        </section>
      </div>
    </div>

    <div class="menu-cta" data-reveal>
      <p>{t.menuPage.ctaText}</p>
      <a href={reservationUrl('menu')} class="btn-cta" rel="noopener" target="_blank">{t.buttons.bookTable}</a>
    </div>
  </div>
</Base>

<style>
  .menu-wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 32px 80px; }
  .menu-grid { display: grid; grid-template-columns: 1.15fr 1fr; gap: 24px; align-items: start; }
  /* One unified frosted glass for every card: a deep wine tint (matching --bg)
     at enough opacity that the drifting field reads as a soft glow behind the
     card, not a bright wash. Plain blur, no saturate (that was over-brightening). */
  .menu-card {
    padding: 32px 36px;
    background: rgba(28, 6, 13, 0.66);
    backdrop-filter: blur(14px);
    border-color: rgba(237, 219, 194, 0.14);
  }
  .menu-stack { display: flex; flex-direction: column; gap: 24px; }
  /* Draught / bottled labels inside the single Beer card. */
  .menu-subsection {
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.14em; color: var(--text-mute); margin: 22px 0 4px;
  }
  .menu-section-label + .menu-subsection { margin-top: 4px; }
  .menu-note {
    font-size: 12px; color: rgba(237, 219, 194, 0.3);
    margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .fw-lead { font-size: 14px; line-height: 1.7; color: rgba(237, 219, 194, 0.6); margin-bottom: 6px; }

  /* === WINE PRICE TABLE (125 ml glass + 750 ml bottle) ===
     Each row is a grid: an info column (1fr) plus two fixed price columns.
     `.prices` is display:contents so the price spans drop straight into the
     row's columns and line up under the volume header. On phones the header is
     dropped and the prices reflow under the name, each labelled by data-vol. */
  .ptable-head { display: grid; align-items: baseline; padding-bottom: 8px; }
  .ptable-2 .ptable-head, .ptable-2 .prow { grid-template-columns: 1fr 72px 88px; }
  .pcol { text-align: right; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-mute); }
  .prow {
    display: grid; align-items: baseline; column-gap: 12px;
    padding: 14px 0; border-bottom: 1px solid rgba(237, 219, 194, 0.08);
  }
  .prow:last-child { border-bottom: none; }
  .prices { display: contents; }
  .pcell { text-align: right; font-size: 13px; font-weight: 600; color: var(--cream); white-space: nowrap; }
  .wine-info { min-width: 0; }
  .wine-name { font-size: 15px; font-weight: 600; color: var(--text); }
