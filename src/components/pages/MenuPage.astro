type BottleGroup = 'vodka' | 'whisky' | 'tequila' | 'rum' | 'liqueur';
const bottleService: { name: string; vol: string; price: string; group: BottleGroup }[] = [
  { group: 'vodka', name: 'Ostoya', vol: '700 ml', price: '269 zł' },
  { group: 'vodka', name: 'Ostoya Black', vol: '700 ml', price: '289 zł' },
  { group: 'vodka', name: 'Grey Goose', vol: '700 ml', price: '400 zł' },
  { group: 'vodka', name: 'Grey Goose Altius', vol: '700 ml', price: '790 zł' },
  { group: 'vodka', name: 'Grey Goose Aurora', vol: '1,75 l', price: '890 zł' },
  { group: 'whisky', name: 'Chivas XII', vol: '700 ml', price: '379 zł' },
  { group: 'whisky', name: 'Chivas XV', vol: '700 ml', price: '450 zł' },
  { group: 'whisky', name: 'Chivas XVIII', vol: '700 ml', price: '630 zł' },
  { group: 'whisky', name: 'Chivas Crystal', vol: '700 ml', price: '379 zł' },
  { group: 'tequila', name: 'Patrón Silver', vol: '700 ml', price: '630 zł' },
  { group: 'tequila', name: 'Patrón Reposado', vol: '700 ml', price: '730 zł' },
  { group: 'tequila', name: 'Patrón Añejo', vol: '700 ml', price: '800 zł' },
  { group: 'rum', name: 'Bumbu Original', vol: '700 ml', price: '420 zł' },
  { group: 'rum', name: 'Bumbu XO', vol: '700 ml', price: '480 zł' },
  { group: 'liqueur', name: 'Jägermeister', vol: '700 ml', price: '350 zł' },
];
const BOTTLE_GROUPS: { key: BottleGroup; label: string }[] = [
  { key: 'vodka', label: t.menuPage.sections.vodka },
  { key: 'whisky', label: t.menuPage.sections.whisky },
  { key: 'tequila', label: t.menuPage.sections.tequila },
  { key: 'rum', label: t.menuPage.sections.rum },
  { key: 'liqueur', label: t.menuPage.sections.liqueurs },
];

const napoje: Item[] = [
  { name: 'Coca-Cola / Coca-Cola Zero', vol: '250 ml', price: '13 zł' },
  { name: 'Coca-Cola', vol: '150 ml', price: '10 zł' },
  { name: 'Sprite / Fanta', vol: '250 ml', price: '13 zł' },
  { name: 'Cappy', desc: 'Grejpfrut / Jabłko / Multiwitamina', vol: '250 ml', price: '13 zł' },
  { name: 'Fuze Tea', desc: 'Brzoskwinia / Hibiskus / Cytryna', vol: '250 ml', price: '15 zł' },
  { name: 'Red Bull', desc: 'Original / Sugar Free / Tropical / Peach', vol: '250 ml', price: '16 zł' },
  { name: '3 Cents', desc: 'Tonic / Aegean Tonic / Grapefruit / Cherry / Lemonade', vol: '250 ml', price: '14 zł' },
  { name: 'Karafka lemoniady', vol: '1000 ml', price: '30 zł' },
  { name: 'Kropla Beskidu', desc: 'Woda mineralna niegazowana', vol: '300 ml', price: '10 zł' },
  { name: 'Délice', desc: 'Woda mineralna gazowana', vol: '300 ml', price: '10 zł' },
];

const piwoLane: Item[] = [
  { name: 'Stella Artois', desc: 'Belgian lager · 5%', vol: '330 / 500 ml', price: '20 / 22 zł' },
  { name: 'Hoegaarden', desc: 'Belgian wheat ale · 4.9%', vol: '330 / 500 ml', price: '22 / 25 zł' },
  { name: 'Leffe Blonde', desc: 'Belgian blonde ale · 6.5%', vol: '330 / 500 ml', price: '25 / 33 zł' },
];

const piwoButelkowe: Item[] = [
  { name: 'Corona Extra', desc: 'Mexican lager · 4.5%', price: '20 zł' },
  { name: 'Corona Cero', desc: 'Mexican lager · 0%', price: '20 zł' },
  { name: 'Leffe', desc: 'Belgian ale · Blonde 6.6% / Brune 6.5%', price: '22 zł' },
  { name: "Beck's", desc: 'German lager · 5%', price: '20 zł' },
  { name: 'Bud', desc: 'American lager · 5%', price: '20 zł' },
];

// Section-header icons (Lucide, MIT + a couple bespoke glyphs). Stroke glyphs
// rendered in --gold next to the Cal Sans label; the inner paths are injected
// with set:html into one <svg>.
const ICONS: Record<string, string> = {
  martini: '<path d="M8 22h8"/><path d="M12 11v11"/><path d="m19 3-7 8-7-8Z"/>',
  glass: '<path d="M5.116 4.104A1 1 0 0 1 6.11 3h11.78a1 1 0 0 1 .994 1.105L17.19 18.21A2 2 0 0 1 15.2 20H8.8a2 2 0 0 1-2-1.79z"/><path d="M6 12a5 5 0 0 1 6 0 5 5 0 0 0 6 0"/>',
  beer: '<path d="M17 11h1a3 3 0 0 1 0 6h-1"/><path d="M9 12v6"/><path d="M13 12v6"/><path d="M14 7.5c-1 0-1.44.5-3 .5s-2-.5-3-.5-1.72.5-2.5.5a2.5 2.5 0 0 1 0-5c.78 0 1.57.5 2.5.5S9.44 3 11 3s2 .5 3 .5 1.72-.5 2.5-.5a2.5 2.5 0 0 1 0 5c-.78 0-1.5-.5-2.5-.5Z"/><path d="M5 8v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8"/>',
  wine: '<path d="M8 22h8"/><path d="M7 10h10"/><path d="M12 15v7"/><path d="M12 15a5 5 0 0 0 5-5c0-2-.5-4-2-8H9c-1.5 4-2 6-2 8a5 5 0 0 0 5 5Z"/>',
  champagne: '<path d="M9 3h6l-.6 7.6a2.4 2.4 0 0 1-4.8 0z"/><path d="M12 13v6"/><path d="M9 21h6"/>',
  bottle: '<path d="M10 3h4"/><path d="M10 3v3l-1.4 2.3A4 4 0 0 0 8 10.4V20a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-9.6a4 4 0 0 0-.6-2.1L14 6V3"/><path d="M8 14h8"/>',
  whisky: '<path d="M5 4h14l-1 15a2 2 0 0 1-2 1.8H8a2 2 0 0 1-2-1.8L5 4z"/><path d="M6 9h12"/>',
  leaf: '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  // Per-spirit glyphs so each foldable range reads at a glance.
  sprig: '<path d="M12 21V9"/><path d="M12 12c-3 0-4.5-1.5-5-4 2.5 0 4 1 5 3.5"/><path d="M12 9c-.5-2.5.6-4.5 3-5 .4 2.5-.6 4.3-3 4.8"/><path d="M12 15c2.5 0 4-1 5-3-2.5-.5-4 .4-5 2.6"/>',
  barrel: '<path d="M7 4h10"/><path d="M7 20h10"/><path d="M7 4c-1.6 5-1.6 11 0 16"/><path d="M17 4c1.6 5 1.6 11 0 16"/><path d="M4.5 9h15"/><path d="M4.5 15h15"/>',
  agave: '<path d="M12 22V8"/><path d="M12 12c-3 0-5-2-6-5 3-.5 5 1 6 4"/><path d="M12 12c3 0 5-2 6-5-3-.5-5 1-6 4"/><path d="M12 17c-2.5 0-4-1.5-5-4 2.5-.4 4 .8 5 3"/><path d="M12 17c2.5 0 4-1.5 5-4-2.5-.4-4 .8-5 3"/>',
  grape: '<path d="M22 5V2l-5.89 5.89"/><circle cx="16.6" cy="15.89" r="3"/><circle cx="8.11" cy="7.4" r="3"/><circle cx="12.35" cy="11.65" r="3"/><circle cx="13.91" cy="5.85" r="3"/><circle cx="18.15" cy="10.09" r="3"/><circle cx="6.56" cy="13.2" r="3"/><circle cx="10.8" cy="17.44" r="3"/><circle cx="5" cy="19" r="3"/>',
  droplet: '<path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>',
  coupe: '<path d="M4 5h16l-3 5a5 5 0 0 1-10 0z"/><path d="M12 15v5"/><path d="M8 20h8"/>',
};
---

<Base
  locale={locale}
  routeKey="menu"
  title={t.meta.menu.title}
  description={t.meta.menu.description}
  ogDescription={t.meta.menu.ogDescription}
>
  <div class="page-header" data-reveal>
    <span class="page-label">{t.menuPage.label}</span>
    <h1 class="page-title display">{t.menuPage.title}</h1>
    <p class="page-subtitle">{t.menuPage.subtitle}</p>
  </div>

  <div class="menu-wrap">
    <div class="menu-grid" data-reveal-group>
      {/* LEFT: cocktails, 0%, core spirits — every section foldable, collapsed. */}
      <div class="menu-stack">
        <MenuFold label={t.menuPage.sections.cocktails} icon={ICONS.martini} count={koktajle.length}>
          {koktajle.map((item) => (
            <MenuItem name={item.name} desc={item.desc ? localizeDesc(item.desc, locale) : undefined} vol={item.vol} price={item.price} />
          ))}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.nonAlcoholic} icon={ICONS.leaf} count={mocktails.length + spirits0.length}>
          <p class="menu-subsection">{t.menuPage.nonAlcSub.cocktails}</p>
          {mocktails.map((item) => (
            <MenuItem name={item.name} desc={item.desc ? localizeDesc(item.desc, locale) : undefined} price={item.price} />
          ))}
          <p class="menu-subsection">{t.menuPage.nonAlcSub.spirits}</p>
          {spirits0.map((item) => (
            <MenuItem name={item.name} vol={item.vol} price={item.price} />
          ))}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.vodka} icon={ICONS.bottle} count={wodka.length} note={t.menuPage.pourNote}>
          {wodka.map((i) => <MenuItem name={i.name} price={i.price} />)}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.gin} icon={ICONS.sprig} count={gin.length} note={t.menuPage.pourNote}>
          {gin.map((i) => <MenuItem name={i.name} price={i.price} />)}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.whisky} icon={ICONS.whisky} count={whisky.length} note={t.menuPage.pourNote}>
          {WHISKY_GROUPS.map((g) => (
            <Fragment>
              <p class="menu-subsection">{g.label}</p>
              {whisky.filter((w) => w.group === g.key).map((w) => <MenuItem name={w.name} price={w.price} />)}
            </Fragment>
          ))}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.rum} icon={ICONS.barrel} count={rum.length} note={t.menuPage.pourNote}>
          {rum.map((i) => <MenuItem name={i.name} desc={i.desc ? localizeDesc(i.desc, locale) : undefined} price={i.price} />)}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.tequila} icon={ICONS.agave} count={tequila.length} note={t.menuPage.pourNote}>
          {tequila.map((i) => <MenuItem name={i.name} price={i.price} />)}
        </MenuFold>
      </div>

      {/* RIGHT: champagne, wine, aperitifs, bottle service, beer, soft drinks. */}
      <div class="menu-stack">
        <MenuFold label={t.menuPage.sections.champagne} icon={ICONS.champagne} count={CHAMPAGNE_HOUSES.reduce((n, h) => n + h.items.length, 0) + 1}>
          {CHAMPAGNE_HOUSES.map((h) => (
            <Fragment>
              <p class="menu-subsection">{h.house}</p>
              {h.items.map((c) => (
                <div class="champ-item">
                  <p class="champ-name">{c.name}</p>
                  <p class="champ-prices">{c.prices.map((p, i) => (p ? `${CHAMP_VOLS[i]} ${p}` : null)).filter(Boolean).join(' · ')}</p>
                </div>
              ))}
            </Fragment>
          ))}
          <p class="menu-subsection">Prosecco</p>
          <div class="champ-item">
            <p class="champ-name">Martini Prosecco</p>
            <p class="champ-prices">150 ml 25 zł · 750 ml 120 zł</p>
          </div>
          <p class="menu-note">{t.menuPage.champagneNote}</p>
        </MenuFold>

        <MenuFold label={t.menuPage.sections.wines} icon={ICONS.wine} count={WINES.length}>
          <p class="fw-lead">{t.menuPage.wineLead}</p>
          <div class="ptable ptable-2">
            <div class="ptable-head" aria-hidden="true">
              <span></span>
              <span class="pcol">150 ml</span>
              <span class="pcol">750 ml</span>
            </div>
            {WINE_CATEGORIES.map((cat) => {
              const list = WINES.filter((w) => w.category === cat.key);
              return list.length === 0 ? null : (
                <Fragment>
                  <p class="menu-subsection">{cat.label[locale]}</p>
                  {list.map((w) => (
                    <div class="prow wine-row">
                      <div class="wine-info">
                        <p class="wine-name">{w.name}{w.vintage ? ` ${w.vintage}` : ''}<span class="wine-winery"> – {w.winery}</span>{w.featured && <span class="wine-featured">{FEATURED_LABEL[locale]}</span>}</p>
                        {(w.dryness || w.grapes) && <p class="wine-meta">{[w.dryness && DRYNESS[w.dryness][locale], w.grapes?.join(', ')].filter(Boolean).join(' · ')}</p>}
                        {w.region && <p class="wine-region">{w.region}</p>}
                      </div>
                      <div class="prices">
                        <span class="pcell" data-vol="150 ml">{w.glassPrice ?? '—'}</span>
                        <span class="pcell" data-vol="750 ml">{w.bottlePrice}</span>
                      </div>
                    </div>
                  ))}
                </Fragment>
              );
            })}
          </div>
        </MenuFold>

        <MenuFold label={t.menuPage.sections.cognac} icon={ICONS.grape} count={koniak.length} note={t.menuPage.pourNote}>
          {koniak.map((i) => <MenuItem name={i.name} price={i.price} />)}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.liqueurs} icon={ICONS.droplet} count={likiery.length} note={t.menuPage.pourNote}>
          {likiery.map((i) => <MenuItem name={i.name} price={i.price} />)}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.vermouth} icon={ICONS.coupe} count={wermuty.length} note={t.menuPage.pourNote}>
          {wermuty.map((i) => <MenuItem name={i.name} price={i.price} />)}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.bottleService} icon={ICONS.bottle} count={bottleService.length}>
          {BOTTLE_GROUPS.map((g) => {
            const list = bottleService.filter((b) => b.group === g.key);
            return list.length === 0 ? null : (
              <Fragment>
                <p class="menu-subsection">{g.label}</p>
                {list.map((b) => <MenuItem name={b.name} vol={b.vol} price={b.price} />)}
              </Fragment>
            );
          })}
        </MenuFold>

        <MenuFold label={t.menuPage.sections.beer} icon={ICONS.beer} count={piwoLane.length + piwoButelkowe.length}>
          <p class="menu-subsection">{t.menuPage.sections.draught}</p>
          {piwoLane.map((item) => (
            <MenuItem name={item.name} desc={item.desc ? localizeDesc(item.desc, locale) : undefined} vol={item.vol} price={item.price} />
          ))}
          <p class="menu-subsection">{t.menuPage.sections.bottled}</p>
          {piwoButelkowe.map((item) => (
            <MenuItem name={item.name} desc={item.desc ? localizeDesc(item.desc, locale) : undefined} vol={item.vol} price={item.price} />
          ))}
          <p class="menu-note">{t.menuPage.bottledNote}</p>
        </MenuFold>

        <MenuFold label={t.menuPage.sections.drinks} icon={ICONS.glass} count={napoje.length}>
          {napoje.map((item) => (
            <MenuItem name={item.name} desc={item.desc ? localizeDesc(item.desc, locale) : undefined} vol={item.vol} price={item.price} />
          ))}
        </MenuFold>
      </div>
    </div>

  </div>

  {/* The Cork kitchen menu — full-bleed cream band, colour-inverted from the bar
      cards above. Lives outside .menu-wrap so it spans edge to edge. Sits above
      the reservation CTA, which closes the page. */}
  <FoodMenu locale={locale} />

  <div class="menu-wrap">
    <div class="menu-cta" data-reveal>
      <p>{t.menuPage.ctaText}</p>
      <a href={reservationUrl('menu')} class="btn-cta" rel="noopener" target="_blank">{t.buttons.bookTable}</a>
    </div>
  </div>
</Base>

<style>
  .menu-wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 32px 80px; }
  .menu-grid { display: grid; grid-template-columns: 1.15fr 1fr; gap: 24px; align-items: start; }
  /* One unified frosted glass for every card: a deep wine tint (matching --bg)
     at enough opacity that the drifting field reads as a soft glow behind the
     card, not a bright wash. Plain blur, no saturate (that was over-brightening). */
  .menu-card {
    padding: 32px 36px;
    background: rgba(28, 6, 13, 0.66);
    backdrop-filter: blur(14px);
    border-color: rgba(237, 219, 194, 0.14);
  }
  .menu-stack { display: flex; flex-direction: column; gap: 24px; }
  /* Draught / bottled labels inside the single Beer card. */
  .menu-subsection {
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.14em; color: var(--text-mute); margin: 22px 0 4px;
  }
  .menu-section-label + .menu-subsection { margin-top: 4px; }
  .menu-note {
    font-size: 12px; color: var(--text-faint);
    margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .fw-lead { font-size: 14px; line-height: 1.7; color: var(--text-dim); margin-bottom: 6px; }

  /* === WINE PRICE TABLE (150 ml glass + 750 ml bottle) ===
     Each row is a grid: an info column (1fr) plus two fixed price columns.
     `.prices` is display:contents so the price spans drop straight into the
     row's columns and line up under the volume header. On phones the header is
     dropped and the prices reflow under the name, each labelled by data-vol. */
  .ptable-head { display: grid; align-items: baseline; padding-bottom: 8px; }
  .ptable-2 .ptable-head, .ptable-2 .prow { grid-template-columns: 1fr 72px 88px; }
  .pcol { text-align: right; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-mute); }
  .prow {
    display: grid; align-items: baseline; column-gap: 12px;
    padding: 14px 0; border-bottom: 1px solid rgba(237, 219, 194, 0.08);
  }
  .prow:last-child { border-bottom: none; }
  .prices { display: contents; }
  .pcell { text-align: right; font-size: 13px; font-weight: 600; color: var(--cream); white-space: nowrap; }
  .wine-info { min-width: 0; }
  .wine-name { font-size: 15px; font-weight: 600; color: var(--text); }
  .wine-winery { font-weight: 400; color: var(--text-dim); }
  .wine-featured {
    margin-left: 8px; font-family: var(--font-display);
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold);
    white-space: nowrap;
  }
  .wine-meta { font-size: 13px; color: var(--text-dim); margin-top: 3px; }
  .wine-region { font-size: 12px; color: var(--text-mute); margin-top: 2px; }
  /* Champagne: name + a flowing line of available sizes (no table). */
  .champ-item { padding: 12px 0; border-bottom: 1px solid rgba(237, 219, 194, 0.08); }
  .champ-item:last-of-type { border-bottom: none; }
  .champ-name { font-size: 15px; font-weight: 600; color: var(--text); }
  .champ-prices { font-size: 13px; color: var(--text-dim); margin-top: 4px; line-height: 1.6; }

  /* CTA now follows the cream food band, which is the section divider — so no
     top rule/margin, just breathing room above the "book a table" prompt. */
  .menu-cta { text-align: center; padding-top: 72px; }
  .menu-cta p { color: var(--text-dim); margin: 0 auto 28px; font-size: 14px; line-height: 1.7; max-width: 360px; }
  @media (max-width: 900px) { .menu-grid { grid-template-columns: 1fr; } }
  @media (max-width: 600px) {
    .menu-wrap { padding-inline: 20px; }
    .menu-card { padding: 28px 24px; }
    /* Collapse the price tables: hide the column header and stack the prices
       under the name, each prefixed with its volume. */
    .ptable-head { display: none; }
    .ptable .prow { grid-template-columns: 1fr; row-gap: 6px; }
    .ptable .prices { display: flex; flex-wrap: wrap; gap: 4px 18px; }
    .pcell { text-align: left; }
    .pcell::before { content: attr(data-vol) "\00a0"; color: var(--text-mute); font-weight: 400; }
  }
</style>
