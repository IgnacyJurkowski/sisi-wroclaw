---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const pricing = useTranslations(locale).privateEvents.pricing;
---

<section class="private-pricing">
  <div class="container">
    <article class="private-pricing-card sisi-card" data-reveal>
      <svg class="private-pricing-icon" viewBox="0 0 24 24" aria-hidden="true"><rect width="8" height="4" x="8" y="2" rx="1" /><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" /><path d="M8 11h8M8 16h6" /></svg>
      <div>
        <h2 class="display private-pricing-title">{pricing.heading}</h2>
        <p class="private-pricing-body">{pricing.body}</p>
      </div>
    </article>
  </div>
</section>

<style>
  .private-pricing { padding: 32px 0 72px; }
  .private-pricing-card { max-width: 820px; margin: 0 auto; padding: 34px 36px; display: flex; align-items: flex-start; gap: 22px; border-color: rgba(251,210,149,0.28); }
  .private-pricing-icon { width: 28px; height: 28px; flex-shrink: 0; fill: none; stroke: var(--gold); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .private-pricing-title { font-size: clamp(1.35rem, 3vw, 1.9rem); text-transform: uppercase; margin-bottom: 10px; }
  .private-pricing-body { color: var(--text-dim); font-size: 15px; line-height: 1.75; }
  @media (max-width: 540px) { .private-pricing-card { padding: 28px 24px; gap: 16px; } }
</style>
