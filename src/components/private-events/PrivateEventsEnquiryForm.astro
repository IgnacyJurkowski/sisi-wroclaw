---
import { CONTACT } from '../../data/site';
import { type Locale } from '../../i18n/config';
import { localizedPath } from '../../i18n/routes';
import { useTranslations } from '../../i18n/t';
import CustomSelect from '../CustomSelect.astro';
import DatePicker from '../DatePicker.astro';
import NumberStepper from '../NumberStepper.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const f = t.privateEvents.form;
const shared = t.b2b.form;
const privacyHref = localizedPath('privacy', locale);
const formMessages = JSON.stringify({
  required: shared.errors.required,
  email: shared.errors.email,
  consent: shared.errors.consent,
  sending: shared.sending,
  submit: shared.submit,
});
const consentParts = shared.consent.split('{privacy}');
const occasionKeys = ['birthday', 'anniversary', 'celebration', 'exclusive', 'other'] as const;
const spaceKeys = ['cork', 'sisi', 'both', 'unsure'] as const;
---

<section id="private-enquiry" class="private-enquiry">
  <div class="container">
    <div class="private-enquiry-head" data-reveal>
      <h2 class="display private-section-title">{f.heading}</h2>
      <p class="private-enquiry-intro">{f.intro}</p>
    </div>

    <form
      class="private-form sisi-card"
      name="private-enquiry"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      data-messages={formMessages}
      data-required-fields="name,email,occasion,guests,preferred_date,message"
      data-event-enquiry-form
      data-private-events-form
      novalidate
      data-reveal
    >
      <input type="hidden" name="form-name" value="private-enquiry" />
      <input type="hidden" name="subject" value={f.subject} />
      <input type="hidden" name="locale" value={locale} />
      <input type="hidden" name="page" data-field-page value="" />
      <input type="hidden" name="utm" data-field-utm value="" />
      <p class="private-hp" aria-hidden="true">
        <input type="text" name="bot-field" tabindex="-1" autocomplete="off" />
      </p>

      <p class="private-form-hint">{shared.requiredHint}</p>
      <div class="private-form-errors" data-form-errors role="alert" tabindex="-1" hidden>{shared.errorSummary}</div>

      <div class="private-fields">
        <div class="private-field">
          <label for="private-name">{f.name} <span class="req" aria-hidden="true">*</span></label>
          <input id="private-name" name="name" type="text" required autocomplete="name" aria-describedby="private-err-name" />
          <p class="private-field-error" id="private-err-name" data-error-for="name" hidden></p>
        </div>

        <div class="private-field">
          <label for="private-email">{shared.email} <span class="req" aria-hidden="true">*</span></label>
          <input id="private-email" name="email" type="email" required autocomplete="email" aria-describedby="private-err-email" />
          <p class="private-field-error" id="private-err-email" data-error-for="email" hidden></p>
        </div>

        <div class="private-field">
          <label for="private-phone">{shared.phone} <span class="opt">{shared.optional}</span></label>
          <input id="private-phone" name="phone" type="tel" autocomplete="tel" />
        </div>

        <div class="private-field">
          <label id="lbl-private-occasion" for="private-occasion">{f.occasion} <span class="req" aria-hidden="true">*</span></label>
          <CustomSelect
            id="private-occasion"
            name="occasion"
            required
            placeholder={f.occasionPlaceholder}
            labelledby="lbl-private-occasion"
            describedby="private-err-occasion"
            options={occasionKeys.map((key) => ({ value: key, label: f.occasionOptions[key] }))}
          />
          <p class="private-field-error" id="private-err-occasion" data-error-for="occasion" hidden></p>
        </div>

        <div class="private-field">
          <label for="private-guests">{shared.guests} <span class="req" aria-hidden="true">*</span></label>
          <NumberStepper
            id="private-guests"
            name="guests"
            min={1}
            required
            describedby="private-err-guests"
            decreaseLabel={shared.guestsDecrease}
            increaseLabel={shared.guestsIncrease}
          />
          <p class="private-field-error" id="private-err-guests" data-error-for="guests" hidden></p>
        </div>

        <div class="private-field">
          <label for="private-date">{shared.date} <span class="req" aria-hidden="true">*</span></label>
          <DatePicker
            id="private-date"
            name="preferred_date"
            locale={locale}
            required
            describedby="private-err-preferred_date"
            placeholder={shared.datePlaceholder}
            modeSingle={shared.dateModeSingle}
            modeRange={shared.dateModeRange}
            prevMonth={shared.datePrevMonth}
            nextMonth={shared.dateNextMonth}
            clear={shared.dateClear}
          />
          <p class="private-field-error" id="private-err-preferred_date" data-error-for="preferred_date" hidden></p>
        </div>

        <div class="private-field">
          <label id="lbl-private-space" for="private-space">{shared.space} <span class="opt">{shared.optional}</span></label>
          <CustomSelect
            id="private-space"
            name="space"
            placeholder={shared.spacePlaceholder}
            labelledby="lbl-private-space"
            options={spaceKeys.map((key) => ({ value: key, label: shared.spaceOptions[key] }))}
          />
        </div>

        <div class="private-field">
          <label for="private-duration">{shared.duration} <span class="opt">{shared.optional}</span></label>
          <input id="private-duration" name="duration" type="text" placeholder={shared.durationPlaceholder} />
        </div>

        <div class="private-field private-field-wide">
          <label for="private-message">{shared.message} <span class="req" aria-hidden="true">*</span></label>
          <textarea id="private-message" name="message" rows="4" required placeholder={f.messagePlaceholder} aria-describedby="private-err-message"></textarea>
          <p class="private-field-error" id="private-err-message" data-error-for="message" hidden></p>
        </div>

        <div class="private-field private-field-wide">
          <label class="private-check private-consent">
            <input type="checkbox" name="consent" value="yes" required aria-describedby="private-err-consent" data-field-consent />
            <span>{consentParts[0]}<a href={privacyHref}>{shared.consentPrivacyLink}</a>{consentParts[1]}</span>
          </label>
          <p class="private-field-error" id="private-err-consent" data-error-for="consent" hidden></p>
        </div>
      </div>

      <div class="private-form-actions">
        <button type="submit" class="btn-cta" data-submit>{shared.submit}</button>
      </div>

      <div class="private-form-status" data-status-success aria-live="polite" tabindex="-1" hidden>
        <p class="private-status-title">{f.success}</p>
      </div>
      <div class="private-form-status private-status-error" data-status-error aria-live="assertive" tabindex="-1" hidden>
        <p class="private-status-title">{shared.error.title}</p>
        <p class="private-status-body">{shared.error.body} <a href={CONTACT.eventsPhoneHref}>{CONTACT.eventsPhone}</a> · <a href={`mailto:${CONTACT.eventsEmail}`}>{CONTACT.eventsEmail}</a></p>
      </div>
    </form>
  </div>
</section>

<script>
  import '../../scripts/event-enquiry-form';
</script>

<style>
  .private-enquiry { padding: 32px 0 96px; }
  .private-enquiry-head { text-align: center; max-width: 680px; margin: 0 auto 40px; }
  .private-section-title { font-size: clamp(1.6rem, 3.6vw, 2.4rem); text-transform: uppercase; }
  .private-enquiry-intro { color: var(--text-dim); font-size: 16px; line-height: 1.8; margin-top: 14px; }
  .private-form { max-width: 820px; margin: 0 auto; padding: 36px 36px 32px; }
  .private-hp { position: absolute; left: -9999px; }
  .private-form-hint { font-size: 12px; color: var(--text-faint); margin-bottom: 18px; }
  .private-form-errors {
    margin-bottom: 20px; padding: 12px 16px; border-radius: 10px;
    border: 1px solid #a8475f; background: rgba(168,71,95,0.15); color: var(--cream); font-size: 14px;
  }
  .private-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 18px 22px; }
  .private-fields > *, .private-field { min-width: 0; }
  .private-field { display: flex; flex-direction: column; gap: 7px; }
  .private-field-wide { grid-column: 1 / -1; }
  .private-field label { font-size: 13px; color: var(--text-dim); }
  .req { color: var(--gold); }
  .opt { color: var(--text-faint); font-size: 11px; }
  .private-field input, .private-field select, .private-field textarea {
    width: 100%; padding: 11px 13px; border-radius: 9px;
    border: 1px solid var(--line); background: rgba(255,255,255,0.03);
    color: var(--cream); font: inherit; font-size: 14px;
  }
  .private-field textarea { resize: vertical; }
  .private-field input:focus, .private-field select:focus, .private-field textarea:focus {
    outline: 2px solid rgba(237,219,194,0.5); outline-offset: 1px; border-color: transparent;
  }
  .private-field [aria-invalid='true'] { border-color: #c25c74; }
  .private-check { flex-direction: row !important; align-items: center; gap: 11px; font-size: 13px; line-height: 1.5; color: var(--text-faint); cursor: pointer; }
  .private-consent { align-items: flex-start; }
  .private-check input[type='checkbox'] {
    appearance: none; -webkit-appearance: none;
    flex-shrink: 0; width: 18px; height: 18px; margin: 0; padding: 0;
    border: 1px solid var(--line); border-radius: 5px;
    background: rgba(255,255,255,0.03); cursor: pointer; position: relative;
    transition: background 150ms ease, border-color 150ms ease;
  }
  .private-consent input[type='checkbox'] { margin-top: 1px; }
  .private-check input[type='checkbox']:hover { border-color: rgba(237,219,194,0.4); }
  .private-check input[type='checkbox']:checked { background: var(--cream); border-color: var(--cream); }
  .private-check input[type='checkbox']:checked::after {
    content: ''; position: absolute; left: 50%; top: 50%; width: 4px; height: 8px;
    border: solid #1a120b; border-width: 0 2px 2px 0;
    transform: translate(-50%, -50%) rotate(45deg);
  }
  .private-check input[type='checkbox']:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
  .private-check input[type='checkbox'][aria-invalid='true'] { border-color: #c25c74; }
  .private-consent a { color: var(--cream); text-decoration: underline; text-underline-offset: 3px; }
  .private-field-error { color: #e7889b; font-size: 12px; }
  .private-form-actions { margin-top: 26px; }
  .private-form-status { margin-top: 22px; padding: 16px 18px; border-radius: 12px; border: 1px solid var(--line); }
  .private-status-title { color: var(--cream); font-size: 15px; line-height: 1.6; }
  .private-status-body { color: var(--text-dim); font-size: 14px; line-height: 1.6; margin-top: 4px; }
  .private-status-error { border-color: #a8475f; }
  .private-status-error a { color: var(--cream); }
  @media (max-width: 640px) { .private-fields { grid-template-columns: 1fr; } .private-form { padding: 28px 22px; } }
</style>
