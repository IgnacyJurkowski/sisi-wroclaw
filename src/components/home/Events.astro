---
import EventCard from '../EventCard.astro';
import { EVENTS } from '../../data/site';

// Homepage teaser - preview the next events, link out to the full page.
const teaser = EVENTS.slice(0, 2);
---

<section id="wydarzenia" class="events">
  <div class="container">
    <span class="page-label" style="text-align:center;display:block;" data-reveal>Wydarzenia</span>
    <h2 class="display ev-title" data-reveal>Nadchodzące wydarzenia</h2>

    <div class="ev-grid" data-reveal-group>
      {teaser.map((e) => <EventCard event={e} />)}
    </div>

    <div class="ev-more" data-reveal>
      <a href="/wydarzenia" class="btn-outline">Zobacz wszystkie wydarzenia</a>
    </div>
  </div>
</section>

<style>
  .events { padding: 96px 0; }
  .ev-title {
    text-align: center; font-size: clamp(2rem, 4.5vw, 3.2rem);
    text-transform: uppercase; margin: 10px 0 48px;
  }
  .ev-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
    max-width: 960px; margin: 0 auto;
  }
  .ev-more { text-align: center; margin-top: 44px; }
  @media (max-width: 700px) { .ev-grid { grid-template-columns: 1fr; } .events { padding: 64px 0; } }
</style>
