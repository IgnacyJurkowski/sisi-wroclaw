---
import EventCard from '../EventCard.astro';
import { splitEvents } from '../../data/site';
import { type Locale } from '../../i18n/config';
import { localizedPath } from '../../i18n/routes';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const eventsHref = localizedPath('events', locale);

// Homepage teaser - preview the soonest upcoming events, link out to the full page.
const upcoming = splitEvents().upcoming;
const teaser = upcoming.slice(0, 2);
---

{upcoming.length > 0 && (
  <section id="wydarzenia" class="events">
    <div class="container">
      <span class="page-label ev-label" data-reveal>{t.homeEvents.eyebrow}</span>
      <h2 class="display ev-title" data-reveal>{t.homeEvents.title}</h2>

      <div class="ev-grid" data-reveal-group>
        {teaser.map((e) => <EventCard event={e} locale={locale} />)}
      </div>

      <div class="ev-more" data-reveal>
        <a href={eventsHref} class="btn-outline">{t.buttons.seeAllEvents}</a>
      </div>
    </div>
  </section>
)}

<style>
  .events { padding: 96px 0; }
  .ev-label { text-align: center; }
  .ev-title {
    text-align: center; font-size: clamp(2rem, 4.5vw, 3.2rem);
    text-transform: uppercase; margin: 10px 0 48px;
  }
  /* Same format as /wydarzenia/: a stacked list of horizontal 16:9 cards. */
  .ev-grid {
    display: flex; flex-direction: column; gap: 20px;
    max-width: var(--maxw); margin: 0 auto;
  }
  .ev-more { text-align: center; margin-top: 44px; }
  @media (max-width: 700px) { .events { padding: 64px 0; } }
</style>
