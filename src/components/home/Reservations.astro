---
import { reservationUrl, CONTACT } from '../../data/site';
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

const mapHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(CONTACT.address)}`;
---

<section id="rezerwacja" class="reservations">
  <div class="container res-grid">
    <div class="res-pitch" data-reveal>
      <span class="page-label">{t.reservationsHome.eyebrow}</span>
      <h2 class="display res-title">{t.reservationsHome.title}</h2>
      <p class="res-body">{t.reservationsHome.body}</p>
      <p class="res-terms-line">{t.reservationsHome.terms}</p>
      <a href={reservationUrl('reservations_section')} class="btn-cta res-cta" rel="noopener" target="_blank">{t.buttons.reserveOnline}</a>
      <p class="res-reassure">{t.reservationsHome.reassure}</p>
    </div>

    <aside class="sisi-card res-info" data-reveal>
      <div class="res-row">
        <span class="res-k">{t.reservationsHome.info.hours}</span>
        <span class="res-v">{t.common.hoursDays}<br />{CONTACT.hours}</span>
      </div>
      <div class="res-row">
        <span class="res-k">{t.reservationsHome.info.address}</span>
        <span class="res-v"><a href={mapHref} rel="noopener" target="_blank">{CONTACT.address}</a></span>
      </div>
      <div class="res-row">
        <span class="res-k">{t.reservationsHome.info.reservations}</span>
        <span class="res-v"><a href={CONTACT.phoneHref}>{CONTACT.phone}</a></span>
      </div>
      <div class="res-row">
        <span class="res-k">{t.reservationsHome.info.corporate}</span>
        <span class="res-v">
          <a href={CONTACT.eventsPhoneHref}>{CONTACT.eventsPhone}</a>
          <a href={`mailto:${CONTACT.eventsEmail}`}>{CONTACT.eventsEmail}</a>
        </span>
      </div>
    </aside>
  </div>
</section>

<style>
  .reservations { padding: 56px 0 96px; }
  .res-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 48px; align-items: center;
    max-width: 1040px; margin: 0 auto;
  }
  .res-title {
    font-size: clamp(2rem, 5vw, 3.4rem);
    text-transform: uppercase; color: var(--cream);
    margin: 12px 0 20px; line-height: 1.05;
  }
  .res-body {
    color: rgba(237, 219, 194, 0.62); font-size: 16px; line-height: 1.8;
    margin-bottom: 28px; max-width: 460px;
  }
  .res-terms-line {
    font-size: 13px; line-height: 1.6; color: rgba(237, 219, 194, 0.72);
    max-width: 460px; margin-bottom: 24px;
    padding: 13px 16px; border: 1px solid var(--line); border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
  }
  .res-cta { padding: 15px 34px; font-size: 13px; }
  .res-reassure {
    margin-top: 18px; font-size: 12px; letter-spacing: 0.03em;
    color: rgba(237, 219, 194, 0.42);
  }

  .res-info { padding: 22px 30px; }
  .res-row {
    display: flex; justify-content: space-between; gap: 24px;
    padding: 16px 0; border-bottom: 1px solid var(--line);
  }
  .res-row:last-child { border-bottom: none; }
  .res-k {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--text-faint); white-space: nowrap; padding-top: 3px;
  }
  .res-v {
    font-size: 14px; color: var(--cream); text-align: right;
    line-height: 1.6; display: flex; flex-direction: column; gap: 2px;
  }
  .res-v a { color: var(--cream); }
  .res-v a:hover { color: var(--cream-hover); }

  @media (max-width: 820px) {
    .res-grid { grid-template-columns: 1fr; gap: 30px; max-width: 520px; }
  }
  @media (max-width: 600px) { .reservations { padding: 32px 0 72px; } }
</style>
