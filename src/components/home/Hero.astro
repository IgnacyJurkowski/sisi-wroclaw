---
import { reservationUrl } from '../../data/site';
import { type Locale } from '../../i18n/config';
import { localizedPath } from '../../i18n/routes';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const eventsHref = localizedPath('events', locale);
---

<section id="start" class="hero">
  <div class="hero-bg" data-parallax="18" aria-hidden="true"></div>
  <div class="hero-scrim" aria-hidden="true"></div>

  <div class="hero-content">
    <h1 class="display hero-title" data-hero>{t.hero.titleLine1}<br />{t.hero.titleLine2}</h1>
    <div class="hero-actions" data-hero>
      <a href={reservationUrl('hero')} class="btn-cta" rel="noopener" target="_blank">{t.nav.reservations}</a>
      <a href={eventsHref} class="btn-outline">{t.buttons.calendar}</a>
    </div>
  </div>

  <a href="#ewolucja-onas" class="hero-scroll" aria-label={t.hero.discover}>
    <span>{t.hero.discover}</span>
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; left: 0; right: 0; top: -15%; height: 130%;
    background: url('/framerusercontent.com/images/nBW0AVejCOoiy2Rctqcid0SY6Q.webp') center/cover no-repeat;
    /* Dissolve the photo's bottom edge so the hero hands off to the circle
       field behind it. Stops account for the -15%/130% parallax overscan, so
       the fade lands near the visible bottom of the section. mask unprefixed
       on purpose (Lightning CSS adds -webkit-mask from browserslist). */
    mask-image: linear-gradient(to bottom, #000 70%, transparent 95%);
  }
  .hero-scrim {
    position: absolute; inset: 0;
    /* Darkens the top/middle for title legibility, then fades to nothing at the
       bottom (was near-opaque wine) so it never covers the sparkle hand-off. */
    background: linear-gradient(180deg, rgba(39,6,15,0.55) 0%, rgba(39,6,15,0.3) 50%, rgba(39,6,15,0) 100%);
  }
  .hero-content { position: relative; z-index: 2; padding: 0 24px; }
  .hero-title {
    font-size: clamp(2.6rem, 8vw, 6rem);
    line-height: 1.05;
    /* No uppercase: Playfair Display SC renders the lowercase as small caps,
       which is the whole point of the SC face (caps would hide it). */
    letter-spacing: 0;
    color: var(--cream);
    text-shadow: 0 2px 40px rgba(0,0,0,0.5);
  }
  .hero-actions {
    display: flex; gap: 16px; justify-content: center;
    margin-top: 40px; flex-wrap: wrap;
  }
  .hero-scroll {
    position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
    z-index: 2;
    /* Padding gives a >=48x48 tap target (the visible label/chevron are small);
       there is ~110px of clearance above, so this never reaches the CTAs. */
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
    min-width: 48px; padding: 10px 18px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.22em;
    color: rgba(237,219,194,0.7);
    animation: bob 2.4s ease-in-out infinite;
  }
  @keyframes bob { 0%,100% { transform: translate(-50%,0); } 50% { transform: translate(-50%,8px); } }
  @media (prefers-reduced-motion: reduce) { .hero-scroll { animation: none; } }
</style>
