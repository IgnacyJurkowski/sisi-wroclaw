---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';
import { variants, CARD_WIDTHS } from '../../lib/img';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

const imgs = [
  { src: '/framerusercontent.com/images/QxXDx4GN74BgGuzaDth23HA.webp', width: 900, height: 599 },
  { src: '/framerusercontent.com/images/RHdmR5s8jXTtyexi8FJLI4WDkig.webp', width: 900, height: 599 },
  { src: '/framerusercontent.com/images/RMGSDUbOPnta4fZZQKL5BcnP3Pw.webp', width: 900, height: 600 },
];
const cards = imgs.map(({ src, width, height }, i) => ({
  img: src,
  width,
  height,
  title: t.about.cards[i],
  v: variants(src, CARD_WIDTHS),
}));
const imgSizes = '(max-width: 600px) 90vw, (max-width: 900px) 45vw, 24vw';
---

<section id="ewolucja-onas" class="about">
  <div class="container about-head" data-reveal>
    <span class="page-label">{t.about.eyebrow}</span>
    <h2 class="display about-title">{t.about.title}</h2>
    <p class="about-intro">{t.about.intro}</p>
  </div>

  <div class="container about-grid" data-reveal-group>
    {cards.map((c) => (
      <figure class="about-card">
        <picture>
          <source type="image/avif" srcset={c.v.avif} sizes={imgSizes} />
          <source type="image/webp" srcset={c.v.webp} sizes={imgSizes} />
          <img src={c.img} alt={c.title} width={c.width} height={c.height} loading="lazy" />
        </picture>
        <figcaption class="display">{c.title}</figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .about { padding: 96px 0; }
  .about-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    text-transform: uppercase; line-height: 1.1; margin: 12px 0 24px;
  }
  /* Intro keeps a readable line length but stays left-aligned, so it starts at
     the same left edge as the grid below (the head block itself now fills the
     shared 70% column). */
  .about-intro { color: var(--text-dim); font-size: 16px; line-height: 1.8; max-width: 640px; }
  .about-grid {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .about-card {
    position: relative; border-radius: 16px; overflow: hidden;
    aspect-ratio: 3 / 4;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .about-card picture { display: contents; }
  .about-card img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 500ms ease;
  }
  .about-card:hover img { transform: scale(1.05); }
  .about-card figcaption {
    position: absolute; inset: auto 0 0 0;
    padding: 28px 22px 22px;
    background: linear-gradient(180deg, transparent, rgba(5,5,5,0.92));
    font-size: 15px; text-transform: uppercase; line-height: 1.3;
    letter-spacing: -0.01em;
  }
  @media (max-width: 900px) { .about-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .about-grid { grid-template-columns: 1fr; } .about { padding: 64px 0; } }
</style>
