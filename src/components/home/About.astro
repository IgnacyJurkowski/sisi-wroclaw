---
const intro = `SISI to przestrzeń, w której wieczór ma swój wyjątkowy rytm. Rozpoczynamy od klimatycznej muzyki na żywo, która tworzy idealne tło dla relaksu i rozmów. Następnie płynnie przechodzimy do dynamicznych setów najlepszych DJ-ów, gwarantujących energię i taniec do samego rana. Tworzymy miejsce dla gości ceniących najwyższą jakość i niezapomnianą, wyjątkową atmosferę.`;

const cards = [
  { img: '/framerusercontent.com/images/QxXDx4GN74BgGuzaDth23HA.webp', title: 'Nowoczesna przestrzeń muzyczna' },
  { img: '/framerusercontent.com/images/RHdmR5s8jXTtyexi8FJLI4WDkig.webp', title: 'Friday Session' },
  { img: '/framerusercontent.com/images/RMGSDUbOPnta4fZZQKL5BcnP3Pw.webp', title: 'Live Acty: muzyczny wstęp do wyjątkowej nocy' },
];
---

<section id="ewolucja-onas" class="about">
  <div class="container about-head" data-reveal>
    <span class="page-label">O nas</span>
    <h2 class="display about-title">Muzyczna ewolucja wieczoru</h2>
    <p class="about-intro">{intro}</p>
  </div>

  <div class="container about-grid" data-reveal-group>
    {cards.map((c) => (
      <figure class="about-card">
        <img src={c.img} alt={c.title} loading="lazy" />
        <figcaption class="display">{c.title}</figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .about { padding: 96px 0; }
  .about-head { max-width: 760px; }
  .about-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    text-transform: uppercase; line-height: 1.1; margin: 12px 0 24px;
  }
  .about-intro { color: rgba(237,219,194,0.6); font-size: 16px; line-height: 1.8; }
  .about-grid {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .about-card {
    position: relative; border-radius: 16px; overflow: hidden;
    aspect-ratio: 3 / 4;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .about-card img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 500ms ease;
  }
  .about-card:hover img { transform: scale(1.05); }
  .about-card figcaption {
    position: absolute; inset: auto 0 0 0;
    padding: 28px 22px 22px;
    background: linear-gradient(180deg, transparent, rgba(5,5,5,0.92));
    font-size: 15px; text-transform: uppercase; line-height: 1.3;
    letter-spacing: -0.01em;
  }
  @media (max-width: 900px) { .about-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .about-grid { grid-template-columns: 1fr; } .about { padding: 64px 0; } }
</style>
