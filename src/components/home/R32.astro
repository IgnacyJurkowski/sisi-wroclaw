---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

// Venue gallery (opening-night photos). These show the live music and the
// crowd, so they carry content, not decoration - real, localized alt text per
// image (describes what is visible; no invented detail).
const gallery: { src: string; alt: Record<Locale, string> }[] = [
  {
    src: '/framerusercontent.com/images/u3EOm1VtOnATOkUYHKikl5aBc.webp',
    alt: {
      pl: 'Wokalistka podczas występu na żywo w SiSi',
      en: 'A vocalist performing live at SiSi',
      de: 'Sängerin bei einem Live-Auftritt im SiSi',
      it: "Una cantante durante un'esibizione dal vivo al SiSi",
      cs: 'Zpěvačka při živém vystoupení v SiSi',
    },
  },
  {
    src: '/framerusercontent.com/images/MHGypGkoM6EkRCjBAVKzMUmwRG4.webp',
    alt: {
      pl: 'Goście na parkiecie podczas imprezy w SiSi',
      en: 'Guests on the dance floor during a night at SiSi',
      de: 'Gäste auf der Tanzfläche während einer Nacht im SiSi',
      it: 'Ospiti in pista durante una serata al SiSi',
      cs: 'Hosté na tanečním parketu během večera v SiSi',
    },
  },
  {
    src: '/framerusercontent.com/images/cDJcCUEanjQSoFpALHKgU3hNpQ.webp',
    alt: {
      pl: 'Zespół grający na żywo na scenie SiSi',
      en: 'A band playing live on the SiSi stage',
      de: 'Eine Band spielt live auf der Bühne im SiSi',
      it: 'Una band suona dal vivo sul palco del SiSi',
      cs: 'Kapela hraje živě na pódiu v SiSi',
    },
  },
];
---

<section class="r32">
  <div class="container r32-top">
    <div class="r32-text" data-reveal>
      <span class="page-label">{t.r32.eyebrow}</span>
      <h2 class="display r32-title">{t.r32.title}</h2>
      <p class="r32-body">{t.r32.body}</p>
      <a href="https://www.r32.com.pl" class="btn-outline" rel="noopener" target="_blank">{t.buttons.discoverR32}</a>
    </div>
  </div>

  <div class="container r32-gallery" data-reveal-group>
    {gallery.map((shot) => (
      <div class="r32-shot"><img src={shot.src} alt={shot.alt[locale]} loading="lazy" /></div>
    ))}
  </div>
</section>

<style>
  .r32 { padding: 96px 0; }
  .r32-top { max-width: 720px; }
  .r32-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    text-transform: uppercase; line-height: 1.1; margin: 12px 0 22px;
  }
  .r32-body { color: rgba(237,219,194,0.6); font-size: 16px; line-height: 1.8; margin-bottom: 32px; }
  .r32-gallery {
    margin-top: 24px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  }
  .r32-shot {
    border-radius: 16px; overflow: hidden; aspect-ratio: 4 / 3;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .r32-shot img { width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 900px) {
    .r32-gallery { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) { .r32 { padding: 64px 0; } .r32-gallery { grid-template-columns: 1fr; } }
</style>
