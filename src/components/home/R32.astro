---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';
import { variants, CARD_WIDTHS } from '../../lib/img';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const imgSizes = '(max-width: 600px) 90vw, (max-width: 900px) 45vw, 24vw';

// Venue gallery (opening-night photos). These show the live music and the
// crowd, so they carry content, not decoration - real, localized alt text per
// image (describes what is visible; no invented detail).
const gallery: { src: string; alt: Record<Locale, string> }[] = [
  {
    src: '/framerusercontent.com/images/u3EOm1VtOnATOkUYHKikl5aBc.webp',
    alt: {
      pl: 'Wokalistka podczas występu na żywo w SiSi',
      en: 'A vocalist performing live at SiSi',
      de: 'Sängerin bei einem Live-Auftritt im SiSi',
      it: "Una cantante durante un'esibizione dal vivo al SiSi",
      cs: 'Zpěvačka při živém vystoupení v SiSi',
    },
  },
  {
    src: '/framerusercontent.com/images/MHGypGkoM6EkRCjBAVKzMUmwRG4.webp',
    alt: {
      pl: 'Goście na parkiecie podczas imprezy w SiSi',
      en: 'Guests on the dance floor during a night at SiSi',
      de: 'Gäste auf der Tanzfläche während einer Nacht im SiSi',
      it: 'Ospiti in pista durante una serata al SiSi',
      cs: 'Hosté na tanečním parketu během večera v SiSi',
    },
  },
  {
    src: '/framerusercontent.com/images/cDJcCUEanjQSoFpALHKgU3hNpQ.webp',
    alt: {
      pl: 'Zespół grający na żywo na scenie SiSi',
      en: 'A band playing live on the SiSi stage',
      de: 'Eine Band spielt live auf der Bühne im SiSi',
      it: 'Una band suona dal vivo sul palco del SiSi',
      cs: 'Kapela hraje živě na pódiu v SiSi',
    },
  },
];
---

<section class="r32">
  <div class="container r32-top">
    <div class="r32-text" data-reveal>
      <span class="page-label">{t.r32.eyebrow}</span>
      <h2 class="display r32-title">{t.r32.title}</h2>
      <p class="r32-body">{t.r32.body}</p>
      <a href="https://www.r32.com.pl" class="btn-outline" rel="noopener" target="_blank">{t.buttons.discoverR32}</a>
    </div>
  </div>

  <div class="container r32-gallery" data-reveal-group>
    {gallery.map((shot, i) => (
      i === 1 ? (
        <div class="r32-shot r32-shot-video">
          <video
            class="r32-vid"
            src="/video/relacja-z-otwarcia.mp4"
            muted loop playsinline preload="none"
            poster="/video/relacja-z-otwarcia-poster-600.webp"
          ></video>
        </div>
      ) : (
        <div class="r32-shot">
          <picture>
            <source type="image/avif" srcset={variants(shot.src, CARD_WIDTHS).avif} sizes={imgSizes} />
            <source type="image/webp" srcset={variants(shot.src, CARD_WIDTHS).webp} sizes={imgSizes} />
            <img src={shot.src} alt={shot.alt[locale]} loading="lazy" />
          </picture>
        </div>
      )
    ))}
  </div>
</section>

<style>
  .r32 { padding: 96px 0; }
  .r32-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    text-transform: uppercase; line-height: 1.1; margin: 12px 0 22px;
  }
  /* Body keeps a readable line length but stays left-aligned, so it starts at
     the same left edge as the gallery below (the top block itself now fills the
     shared 70% column). */
  .r32-body { color: var(--text-dim); font-size: 16px; line-height: 1.8; margin-bottom: 32px; max-width: 640px; }
  .r32-gallery {
    margin-top: 24px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  }
  .r32-shot {
    border-radius: 16px; overflow: hidden; aspect-ratio: 4 / 3;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .r32-shot picture { display: contents; }
  .r32-shot img, .r32-shot video { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (max-width: 900px) {
    .r32-gallery { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .r32 { padding: 64px 0; }
    /* On phones, show only the middle tile (the video); hide the side photos. */
    .r32-gallery { grid-template-columns: 1fr; }
    .r32-shot:not(.r32-shot-video) { display: none; }
  }
</style>

<script>
  // The recap clip is below the fold, so don't download it on load (preload
  // none). Start playback only when the section is about to enter view -
  // keeps the ~5MB video out of the initial/critical load path.
  const vid = document.querySelector<HTMLVideoElement>('video.r32-vid');
  if (vid) {
    const io = new IntersectionObserver((entries, obs) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          vid.play().catch(() => {});
          obs.disconnect();
        }
      }
    }, { rootMargin: '300px 0px' });
    io.observe(vid);
  }
</script>
