---
/* Opening-night recap reel. The mp4 lives in public/video/ (large static
   media is served statically, not run through Astro's image pipeline). The
   video downloads only on play (preload="metadata"), so it never blocks the
   homepage first paint. */
const src = '/video/relacja-z-otwarcia.mp4';
const poster = '/video/relacja-z-otwarcia-poster.jpg';
---

<section class="recap">
  <div class="container recap-inner" data-reveal-group>
    <span class="page-label" style="text-align:center;display:block;">Relacja</span>
    <h2 class="display recap-title">Noc otwarcia</h2>
    <p class="recap-body">
      Światła, muzyka i ludzie, którzy tworzą SiSi.<br />
      Zobacz, jak wyglądał pierwszy wieczór w sercu kompleksu R32.
    </p>
    <div class="recap-frame" data-reveal>
      <video src={src} poster={poster} controls preload="metadata" playsinline></video>
    </div>
  </div>
</section>

<style>
  .recap { padding: 96px 0; }
  .recap-inner { max-width: 920px; text-align: center; }
  .recap-title { font-size: clamp(2rem, 5vw, 3.4rem); text-transform: uppercase; margin: 10px 0 18px; }
  .recap-body { color: rgba(237,219,194,0.6); font-size: 16px; line-height: 1.8; margin-bottom: 36px; }
  .recap-frame {
    border-radius: 16px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    aspect-ratio: 16 / 9; background: var(--panel);
    box-shadow: 0 24px 60px rgba(0,0,0,0.45);
  }
  .recap-frame video { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (max-width: 600px) { .recap { padding: 64px 0; } }
</style>
