---
import { reservationUrl } from '../data/site';
import type { EventItem } from '../data/site';
import { type Locale } from '../i18n/config';
import { formatEventDate, dateTimeAttr } from '../i18n/format';
import { useTranslations } from '../i18n/t';

interface Props { event: EventItem; locale: Locale; past?: boolean }
const { event, locale, past = false } = Astro.props;
const t = useTranslations(locale);
---

<article class:list={['ev-card', { past }]}>
  <div class="ev-media"><img src={event.img} alt={event.title} loading="lazy" /></div>
  <div class="ev-body">
    <h3 class="display ev-name">{event.title}</h3>
    {event.note && <p class="ev-note">{event.note}</p>}
    <p class="ev-date"><time datetime={dateTimeAttr(event.start)}>{formatEventDate(event.start, locale)}</time></p>
    {past
      ? <span class="ev-done">{t.eventCard.finished}</span>
      : <a href={reservationUrl('event_card')} class="btn-cta" rel="noopener" target="_blank">{t.eventCard.reserve}</a>}
  </div>
</article>

<style>
  .ev-card {
    background: var(--panel); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px; overflow: hidden;
    display: flex; flex-direction: column;
  }
  .ev-media { aspect-ratio: 4 / 3; overflow: hidden; }
  .ev-media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 500ms ease;
  }
  .ev-card:hover .ev-media img { transform: scale(1.04); }
  .ev-body { padding: 28px 30px 30px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .ev-name { font-size: 1.3rem; text-transform: uppercase; }
  .ev-note { font-size: 13px; color: var(--cream); text-transform: uppercase; letter-spacing: 0.08em; }
  .ev-date { font-size: 14px; color: rgba(237,219,194,0.55); margin-bottom: 18px; }
  .ev-body .btn-cta { margin-top: auto; align-self: flex-start; }

  /* Archive variant: dimmed, no booking (the event is over). */
  .ev-card.past { opacity: 0.82; }
  .ev-card.past .ev-media img { filter: grayscale(0.35) brightness(0.7); }
  .ev-done {
    margin-top: auto; align-self: flex-start;
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-mute); border: 1px solid var(--line);
    padding: 9px 16px; border-radius: 10px;
  }
</style>
