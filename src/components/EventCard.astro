---
import { reservationUrl } from '../data/site';
import type { EventItem } from '../data/site';
import { type Locale } from '../i18n/config';
import { eventPath } from '../i18n/routes';
import { formatEventDate, dateTimeAttr } from '../i18n/format';
import { useTranslations } from '../i18n/t';
import { variants, BANNER_WIDTHS } from '../lib/img';

interface Props { event: EventItem; locale: Locale; past?: boolean }
const { event, locale, past = false } = Astro.props;
const t = useTranslations(locale);
const href = eventPath(event.slug, locale);
const v = variants(event.img, BANNER_WIDTHS);
const imgSizes = '(max-width: 640px) 92vw, 30vw';
---

<article class:list={['ev-card', { past }]}>
  <a class="ev-media" href={href} aria-label={event.title}>
    <picture>
      <source type="image/avif" srcset={v.avif} sizes={imgSizes} />
      <source type="image/webp" srcset={v.webp} sizes={imgSizes} />
      <img src={event.img} alt={event.title} loading="lazy" />
    </picture>
  </a>
  <div class="ev-body">
    <h3 class="display ev-name"><a href={href}>{event.title}</a></h3>
    {event.note && <p class="ev-note">{event.note}</p>}
    {event.genres && event.genres.length > 0 && (
      <ul class="ev-genres">{event.genres.map((g) => <li>{g}</li>)}</ul>
    )}
    <p class="ev-date"><time datetime={dateTimeAttr(event.start)}>{formatEventDate(event.start, locale)}</time></p>
    {event.description && <p class="ev-desc">{event.description}</p>}
    <div class="ev-foot">
      {event.price != null && (
        <span class="ev-price">{event.price === 0 ? t.eventCard.freeEntry : `${t.eventCard.entry} ${event.price} zł`}</span>
      )}
      {past
        ? <span class="ev-done">{t.eventCard.finished}</span>
        : <a href={reservationUrl('event_card')} class="btn-cta" rel="noopener" target="_blank">{t.eventCard.reserve}</a>}
    </div>
  </div>
</article>

<style>
  .ev-card {
    /* glass — same recipe as the nav/cards; the media column stays opaque, the
       body frosts the circle field behind it. backdrop-filter unprefixed
       (Lightning CSS adds -webkit-). */
    background: rgba(39, 7, 15, 0.42);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(237, 219, 194, 0.18);
    border-radius: 16px; overflow: hidden;
    display: grid; grid-template-columns: minmax(0, 44%) 1fr;
  }
  /* 16:9 media that fills the column; padding-hack keeps the ratio even when the
     body column is taller. */
  .ev-media { position: relative; display: block; overflow: hidden; }
  .ev-media picture { display: contents; }
  .ev-media::before { content: ''; display: block; padding-top: 56.25%; }
  .ev-media img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    transition: transform 500ms ease;
  }
  .ev-card:hover .ev-media img { transform: scale(1.04); }

  .ev-body { padding: 24px 30px; display: flex; flex-direction: column; gap: 8px; }
  .ev-name { font-size: 1.4rem; text-transform: uppercase; }
  .ev-name a { color: inherit; text-decoration: none; }
  .ev-name a:hover { color: var(--cream); }
  .ev-note { font-size: 13px; color: var(--cream); text-transform: uppercase; letter-spacing: 0.08em; }
  .ev-genres { display: flex; flex-wrap: wrap; gap: 6px; margin: 2px 0 0; padding: 0; list-style: none; }
  .ev-genres li {
    font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-mute); border: 1px solid var(--line);
    padding: 3px 9px; border-radius: 99px;
  }
  .ev-date { font-size: 14px; color: rgba(237,219,194,0.55); }
  .ev-desc {
    font-size: 13px; line-height: 1.5; color: var(--text-dim); margin: 0;
    display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; line-clamp: 2;
    overflow: hidden;
  }
  .ev-foot {
    margin-top: auto; padding-top: 14px;
    display: flex; align-items: center; flex-wrap: wrap; gap: 14px;
  }
  .ev-price { font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--gold); }

  /* Archive variant: dimmed, no booking (the event is over). */
  .ev-card.past { opacity: 0.82; }
  .ev-card.past .ev-media img { filter: grayscale(0.35) brightness(0.7); }
  .ev-done {
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-mute); border: 1px solid var(--line);
    padding: 9px 16px; border-radius: 10px;
  }

  /* Stack on narrow screens: image on top (16:9), details below. */
  @media (max-width: 640px) {
    .ev-card { grid-template-columns: 1fr; }
    .ev-body { padding: 22px 22px 26px; }
  }
</style>
