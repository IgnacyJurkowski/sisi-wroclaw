---
import Logo from './Logo.astro';
import SocialIcon from './SocialIcon.astro';
import { CONTACT, EVENTS } from '../data/site';
import { type Locale } from '../i18n/config';
import { NAV_KEYS, FOOTER_LEGAL_KEYS, localizedPath } from '../i18n/routes';
import { useTranslations } from '../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

const pages = NAV_KEYS
  .filter((key) => key !== 'events' || EVENTS.length > 0)
  .map((key) => ({ href: localizedPath(key, locale), label: t.nav[key] }));
const legal = FOOTER_LEGAL_KEYS.map((k) => ({ href: localizedPath(k, locale), label: t.nav[k] }));
const homeHref = localizedPath('home', locale);
---

<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={homeHref} class="footer-logo" aria-label={t.nav.homeAria}><Logo /></a>
        <p class="footer-tagline">{t.footer.tagline}</p>
      </div>

      <div>
        <p class="footer-col-heading">{t.footer.pagesHeading}</p>
        {pages.map((p) => <a href={p.href} class="footer-link">{p.label}</a>)}
      </div>

      <div>
        <p class="footer-col-heading">{t.footer.contactHeading}</p>
        <a href={`mailto:${CONTACT.email}`} class="footer-link">{CONTACT.email}</a>
        <a href={CONTACT.mapsUrl} class="footer-link" rel="noopener" target="_blank">{CONTACT.address}</a>
        <a href={CONTACT.phoneHref} class="footer-link">{CONTACT.phone}</a>
      </div>

      <div>
        <p class="footer-col-heading">{t.footer.hoursHeading}</p>
        <span class="footer-text footer-text-strong">{t.common.hoursDays}</span>
        <span class="footer-text">{CONTACT.hours}</span>
        <div class="footer-social">
          <a href={CONTACT.instagram} class="social-icon" rel="noopener" target="_blank" aria-label="Instagram"><SocialIcon name="instagram" /></a>
          <a href={CONTACT.facebook} class="social-icon" rel="noopener" target="_blank" aria-label="Facebook"><SocialIcon name="facebook" /></a>
          <a href={CONTACT.tripadvisor} class="social-icon" rel="noopener" target="_blank" aria-label="Tripadvisor"><SocialIcon name="tripadvisor" /></a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>{t.footer.rights}</p>
      <nav class="footer-legal" aria-label={t.footer.legalHeading}>
        {legal.map((p) => <a href={p.href}>{p.label}</a>)}
      </nav>
    </div>
  </div>
</footer>
