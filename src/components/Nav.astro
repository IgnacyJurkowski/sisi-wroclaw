---
import Logo from './Logo.astro';
import SocialIcon from './SocialIcon.astro';
import LocaleSwitcher from './LocaleSwitcher.astro';
import { CONTACT } from '../data/site';
import { type Locale } from '../i18n/config';
import { NAV_KEYS, localizedPath, type RouteKey } from '../i18n/routes';
import { useTranslations } from '../i18n/t';

interface Props { locale: Locale; active?: RouteKey }
const { locale, active } = Astro.props;
const t = useTranslations(locale);

const links = NAV_KEYS.map((key) => ({ key, href: localizedPath(key, locale), label: t.nav[key] }));
const homeHref = localizedPath('home', locale);
const reservationsHref = localizedPath('reservations', locale);
---

<a href="#main" class="skip-link">{t.nav.skip}</a>

<nav id="main-nav" role="navigation" aria-label={t.nav.mainNav}>
  <div class="nav-left">
    <a href={homeHref} class="nav-logo" aria-label={t.nav.homeAria}><Logo /></a>
  </div>
  <div class="nav-center">
    <div class="nav-links">
      {links.map((p) => (
        <a href={p.href} aria-current={p.key === active ? 'page' : undefined}>{p.label}</a>
      ))}
    </div>
    <a href={reservationsHref} class="nav-cta">{t.nav.reservations}</a>
  </div>
  <div class="nav-right">
    <div class="nav-social">
      <a href={CONTACT.instagram} class="social-icon" rel="noopener" target="_blank" aria-label="Instagram"><SocialIcon name="instagram" /></a>
      <a href={CONTACT.facebook} class="social-icon" rel="noopener" target="_blank" aria-label="Facebook"><SocialIcon name="facebook" /></a>
      <a href={CONTACT.tripadvisor} class="social-icon" rel="noopener" target="_blank" aria-label="Tripadvisor"><SocialIcon name="tripadvisor" /></a>
    </div>
    <div class="nav-lang"><LocaleSwitcher locale={locale} routeKey={active ?? 'home'} variant="bar" /></div>
  </div>
  <button id="hamburger" aria-label={t.nav.openMenu} aria-expanded="false" aria-controls="mobile-menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div id="mobile-menu" hidden role="dialog" aria-label={t.nav.mobileNav} aria-modal="true">
  <button id="mobile-close" aria-label={t.nav.closeMenu}>&times;</button>
  {links.map((p) => (
    <a href={p.href} class:list={[{ active: p.key === active }]} data-nav-link>{p.label}</a>
  ))}
  <a href={reservationsHref} class="btn-cta" data-nav-link style="margin-top:1rem;">{t.nav.reservations}</a>
  <LocaleSwitcher locale={locale} routeKey={active ?? 'home'} variant="inline" />
</div>
