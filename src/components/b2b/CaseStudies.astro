---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';
import { publishedCaseStudies } from '../../data/caseStudies';
import CaseStudyCard from './CaseStudyCard.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

// Render the grid only when a real, verified project is published. Otherwise a
// neutral message - never a fabricated client.
const projects = publishedCaseStudies();
---

<section class="b2b-projects">
  <div class="container">
    <h2 class="display b2b-section-title">{t.b2b.projects.heading}</h2>
    {projects.length > 0 ? (
      <div class="b2b-projects-grid" data-reveal-group>
        {projects.map((p) => <CaseStudyCard study={p} locale={locale} />)}
      </div>
    ) : (
      <div class="b2b-projects-empty" data-reveal>
        <p class="b2b-projects-empty-title">{t.b2b.projects.emptyTitle}</p>
        <p class="b2b-projects-empty-body">{t.b2b.projects.emptyBody}</p>
      </div>
    )}
  </div>
</section>

<style>
  .b2b-projects { padding: 32px 0 72px; }
  .b2b-section-title { font-size: clamp(1.5rem, 3.4vw, 2.2rem); text-transform: uppercase; text-align: center; margin-bottom: 36px; }
  .b2b-projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .b2b-projects-empty {
    max-width: 560px; margin: 0 auto; text-align: center;
    border: 1px dashed var(--line); border-radius: 16px; padding: 44px 28px;
  }
  .b2b-projects-empty-title { color: var(--cream); font-size: 18px; line-height: 1.5; margin-bottom: 8px; }
  .b2b-projects-empty-body { color: rgba(237,219,194,0.55); font-size: 14px; }
  @media (max-width: 900px) { .b2b-projects-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .b2b-projects-grid { grid-template-columns: 1fr; } }
</style>
