---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';
import { publishedCaseStudies } from '../../data/caseStudies';
import CaseStudyCard from './CaseStudyCard.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

// Render this proof section only when a real, verified project is published.
const projects = publishedCaseStudies();
---

{projects.length > 0 && (
  <section class="b2b-projects">
    <div class="container">
      <h2 class="display b2b-section-title">{t.b2b.projects.heading}</h2>
      <div class="b2b-projects-grid" data-reveal-group>
        {projects.map((p) => <CaseStudyCard study={p} locale={locale} />)}
      </div>
    </div>
  </section>
)}

<style>
  .b2b-projects { padding: 32px 0 72px; }
  .b2b-section-title { font-size: clamp(1.5rem, 3.4vw, 2.2rem); text-transform: uppercase; text-align: center; margin-bottom: 36px; }
  .b2b-projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  @media (max-width: 900px) { .b2b-projects-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .b2b-projects-grid { grid-template-columns: 1fr; } }
</style>
