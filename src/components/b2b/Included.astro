---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const f = t.b2b.included;

// Icons align by index to included.items: bar, catering, music, cloakroom,
// zone separation, decor & cake, cleaning, coordination. Decorative.
const ICONS = [
  '<path d="M8 22h8"/><path d="M12 11v11"/><path d="m19 3-7 8-7-8Z"/>',
  '<path d="M17 21a1 1 0 0 0 1-1v-5.35c0-.457.316-.844.727-1.041a4 4 0 0 0-2.134-7.589 5 5 0 0 0-9.186 0 4 4 0 0 0-2.134 7.588c.411.198.727.585.727 1.041V20a1 1 0 0 0 1 1Z"/><path d="M6 17h12"/>',
  '<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
  '<path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/>',
  '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 3v18"/>',
  '<path d="M20 21v-8a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8"/><path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2-1 2-1"/><path d="M2 21h20"/><path d="M7 8v3"/><path d="M12 8v3"/><path d="M17 8v3"/><path d="M7 4h.01"/><path d="M12 4h.01"/><path d="M17 4h.01"/>',
  '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>',
  '<rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/>',
];
---

<section class="b2b-included">
  <div class="container">
    <h2 class="display b2b-section-title">{f.heading}</h2>
    <p class="b2b-section-intro">{f.intro}</p>
    <ul class="b2b-included-grid" data-reveal-group>
      {f.items.map((item, i) => (
        <li class="b2b-included-item sisi-card">
          <svg class="b2b-included-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS[i]} />
          <h3 class="b2b-included-title">{item.title}</h3>
          <p class="b2b-included-body">{item.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .b2b-included { padding: 32px 0 72px; }
  .b2b-section-title { font-size: clamp(1.5rem, 3.4vw, 2.2rem); text-transform: uppercase; text-align: center; margin-bottom: 14px; }
  .b2b-section-intro { text-align: center; color: rgba(237,219,194,0.6); font-size: 15px; line-height: 1.7; max-width: 560px; margin: 0 auto 40px; }
  .b2b-included-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
  }
  .b2b-included-item { padding: 26px 24px; }
  .b2b-included-icon {
    width: 24px; height: 24px; display: block; margin-bottom: 14px;
    fill: none; stroke: var(--gold); stroke-width: 1.5;
    stroke-linecap: round; stroke-linejoin: round; opacity: 0.9;
  }
  .b2b-included-title { font-size: 16px; text-transform: uppercase; letter-spacing: 0.02em; color: var(--cream); margin-bottom: 10px; }
  .b2b-included-body { font-size: 13px; line-height: 1.6; color: rgba(237,219,194,0.55); }
  @media (max-width: 900px) { .b2b-included-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .b2b-included-grid { grid-template-columns: 1fr; } }
</style>
