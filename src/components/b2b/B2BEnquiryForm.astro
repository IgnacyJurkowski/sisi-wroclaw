---
import { type Locale } from '../../i18n/config';
import { localizedPath } from '../../i18n/routes';
import { useTranslations } from '../../i18n/t';
import { CONTACT } from '../../data/site';
import CustomSelect from '../CustomSelect.astro';
import NumberStepper from '../NumberStepper.astro';
import DatePicker from '../DatePicker.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const f = t.b2b.form;
const cta = t.b2b.finalCta;
const privacyHref = localizedPath('privacy', locale);
const formMessages = JSON.stringify({
  required: f.errors.required,
  email: f.errors.email,
  consent: f.errors.consent,
  sending: f.sending,
  submit: f.submit,
});

// Consent label embeds a {privacy} link -> 2 plain-text segments.
const consentParts = f.consent.split('{privacy}');
const eventTypeKeys = ['conference', 'panel', 'presentation', 'launch', 'dinner', 'networking', 'party', 'private', 'other'] as const;
const spaceKeys = ['cork', 'sisi', 'both', 'unsure'] as const;
---

<section id="b2b-enquiry" class="b2b-enquiry">
  <div class="container">
    <div class="b2b-enquiry-head" data-reveal>
      <h2 class="display b2b-section-title">{cta.heading}</h2>
      <p class="b2b-enquiry-intro">{cta.body}</p>
    </div>

    <form
      class="b2b-form sisi-card"
      name="b2b-enquiry"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      data-messages={formMessages}
      data-b2b-form
      novalidate
      data-reveal
    >
      <input type="hidden" name="form-name" value="b2b-enquiry" />
      <input type="hidden" name="locale" value={locale} />
      <input type="hidden" name="page" data-field-page value="" />
      <input type="hidden" name="utm" data-field-utm value="" />
      <!-- Netlify honeypot: kept in the markup for spam filtering, but hidden
           from sight (.b2b-hp), from the a11y tree (aria-hidden), and from the
           tab order (tabindex=-1). No visible/announced label text. -->
      <p class="b2b-hp" aria-hidden="true">
        <input type="text" name="bot-field" tabindex="-1" autocomplete="off" />
      </p>

      <p class="b2b-form-hint">{f.requiredHint}</p>

      <div class="b2b-form-errors" data-form-errors role="alert" tabindex="-1" hidden>{f.errorSummary}</div>

      <div class="b2b-fields">
        <div class="b2b-field">
          <label for="b2b-company">{f.companyName} <span class="req" aria-hidden="true">*</span></label>
          <input id="b2b-company" name="company" type="text" required autocomplete="organization" aria-describedby="err-company" />
          <p class="b2b-field-error" id="err-company" data-error hidden></p>
        </div>

        <div class="b2b-field">
          <label for="b2b-person">{f.contactPerson} <span class="req" aria-hidden="true">*</span></label>
          <input id="b2b-person" name="contact_person" type="text" required autocomplete="name" aria-describedby="err-contact_person" />
          <p class="b2b-field-error" id="err-contact_person" data-error hidden></p>
        </div>

        <div class="b2b-field">
          <label for="b2b-email">{f.email} <span class="req" aria-hidden="true">*</span></label>
          <input id="b2b-email" name="email" type="email" required autocomplete="email" aria-describedby="err-email" />
          <p class="b2b-field-error" id="err-email" data-error hidden></p>
        </div>

        <div class="b2b-field">
          <label for="b2b-phone">{f.phone} <span class="opt">{f.optional}</span></label>
          <input id="b2b-phone" name="phone" type="tel" autocomplete="tel" />
        </div>

        <div class="b2b-field">
          <label id="lbl-b2b-type" for="b2b-type">{f.eventType} <span class="req" aria-hidden="true">*</span></label>
          <CustomSelect
            id="b2b-type"
            name="event_type"
            required
            placeholder={f.eventTypePlaceholder}
            labelledby="lbl-b2b-type"
            describedby="err-event_type"
            options={eventTypeKeys.map((k) => ({ value: k, label: f.eventTypeOptions[k] }))}
          />
          <p class="b2b-field-error" id="err-event_type" data-error hidden></p>
        </div>

        <div class="b2b-field">
          <label for="b2b-guests">{f.guests} <span class="req" aria-hidden="true">*</span></label>
          <NumberStepper
            id="b2b-guests"
            name="guests"
            min={1}
            required
            describedby="err-guests"
            decreaseLabel={f.guestsDecrease}
            increaseLabel={f.guestsIncrease}
          />
          <p class="b2b-field-error" id="err-guests" data-error hidden></p>
        </div>

        <div class="b2b-field">
          <label for="b2b-date">{f.date} <span class="req" aria-hidden="true">*</span></label>
          <DatePicker
            id="b2b-date"
            name="preferred_date"
            locale={locale}
            required
            describedby="err-preferred_date"
            placeholder={f.datePlaceholder}
            modeSingle={f.dateModeSingle}
            modeRange={f.dateModeRange}
            prevMonth={f.datePrevMonth}
            nextMonth={f.dateNextMonth}
            clear={f.dateClear}
          />
          <label class="b2b-check">
            <input type="checkbox" name="date_flexible" value="yes" data-field-flexible /> {f.dateFlexible}
          </label>
          <p class="b2b-field-error" id="err-preferred_date" data-error hidden></p>
        </div>

        <div class="b2b-field">
          <label id="lbl-b2b-space" for="b2b-space">{f.space} <span class="opt">{f.optional}</span></label>
          <CustomSelect
            id="b2b-space"
            name="space"
            placeholder={f.spacePlaceholder}
            labelledby="lbl-b2b-space"
            options={spaceKeys.map((k) => ({ value: k, label: f.spaceOptions[k] }))}
          />
        </div>

        <div class="b2b-field">
          <label for="b2b-duration">{f.duration} <span class="opt">{f.optional}</span></label>
          <input id="b2b-duration" name="duration" type="text" placeholder={f.durationPlaceholder} />
        </div>

        <div class="b2b-field b2b-field-wide">
          <label for="b2b-presentation">{f.presentation} <span class="opt">{f.optional}</span></label>
          <input id="b2b-presentation" name="presentation" type="text" />
        </div>

        <div class="b2b-field">
          <label for="b2b-catering">{f.catering} <span class="opt">{f.optional}</span></label>
          <input id="b2b-catering" name="catering" type="text" />
        </div>

        <div class="b2b-field">
          <label for="b2b-technical">{f.technical} <span class="opt">{f.optional}</span></label>
          <input id="b2b-technical" name="technical" type="text" />
        </div>

        <div class="b2b-field b2b-field-wide">
          <label for="b2b-message">{f.message} <span class="req" aria-hidden="true">*</span></label>
          <textarea id="b2b-message" name="message" rows="4" required placeholder={f.messagePlaceholder} aria-describedby="err-message"></textarea>
          <p class="b2b-field-error" id="err-message" data-error hidden></p>
        </div>

        <div class="b2b-field b2b-field-wide">
          <label class="b2b-check b2b-consent">
            <input type="checkbox" name="consent" value="yes" required aria-describedby="err-consent" data-field-consent />
            <span>{consentParts[0]}<a href={privacyHref}>{f.consentPrivacyLink}</a>{consentParts[1]}</span>
          </label>
          <p class="b2b-field-error" id="err-consent" data-error hidden></p>
        </div>
      </div>

      <div class="b2b-form-actions">
        <button type="submit" class="btn-cta" data-submit>{f.submit}</button>
      </div>

      <div class="b2b-form-status" data-status-success aria-live="polite" hidden>
        <p class="b2b-status-title">{f.success.title}</p>
        <p class="b2b-status-body">{f.success.body}</p>
      </div>
      <div class="b2b-form-status b2b-status-error" data-status-error aria-live="assertive" hidden>
        <p class="b2b-status-title">{f.error.title}</p>
        <p class="b2b-status-body">{f.error.body} <a href={CONTACT.eventsPhoneHref}>{CONTACT.eventsPhone}</a> · <a href={`mailto:${CONTACT.eventsEmail}`}>{CONTACT.eventsEmail}</a></p>
      </div>
    </form>
  </div>
</section>

<script>
  import { campaignAttribution } from '../../lib/attribution.mjs';

  (function () {
    const formElement = document.querySelector('[data-b2b-form]');
    if (!(formElement instanceof HTMLFormElement)) return;
    const form: HTMLFormElement = formElement;
    const messages = JSON.parse(form.getAttribute('data-messages') || '{}') as Record<string, string>;

    // Fill page context and bounded campaign-attribution fields from the URL.
    // Unrelated query parameters are never submitted.
    try {
      const pageEl = form.querySelector<HTMLInputElement>('[data-field-page]');
      const utmEl = form.querySelector<HTMLInputElement>('[data-field-utm]');
      if (pageEl) pageEl.value = location.pathname;
      if (utmEl) utmEl.value = campaignAttribution(location.search);
    } catch {}

    const errBox = form.querySelector<HTMLElement>('[data-form-errors]');
    const okBox = form.querySelector<HTMLElement>('[data-status-success]');
    const failBox = form.querySelector<HTMLElement>('[data-status-error]');
    const submit = form.querySelector<HTMLButtonElement>('[data-submit]');
    if (!submit) return;

    function setError(name: string, msg: string): void {
      const field = form.querySelector<HTMLElement>('[name="' + name + '"]');
      const errEl = document.getElementById('err-' + name);
      if (field) field.setAttribute('aria-invalid', 'true');
      if (errEl) { errEl.textContent = msg; errEl.hidden = false; }
    }
    function clearErrors(): void {
      form.querySelectorAll<HTMLElement>('[data-error]').forEach(function (e) { e.hidden = true; e.textContent = ''; });
      form.querySelectorAll('[aria-invalid]').forEach(function (e) { e.removeAttribute('aria-invalid'); });
      if (errBox) errBox.hidden = true;
    }
    function validate(): boolean {
      clearErrors();
      let firstBad: HTMLElement | null = null;
      const required = ['company', 'contact_person', 'email', 'event_type', 'guests', 'message'];
      required.forEach(function (n) {
        const el = form.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[name="' + n + '"]');
        if (el && !String(el.value).trim()) { setError(n, messages.required); firstBad = firstBad || el; }
      });
      const email = form.querySelector<HTMLInputElement>('[name="email"]');
      if (email && email.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) {
        setError('email', messages.email); firstBad = firstBad || email;
      }
      const flexible = form.querySelector<HTMLInputElement>('[data-field-flexible]');
      const date = form.querySelector<HTMLInputElement>('[data-field-date]');
      if (date && !date.value.trim() && !(flexible && flexible.checked)) {
        setError('preferred_date', messages.required); firstBad = firstBad || date;
      }
      const consent = form.querySelector<HTMLInputElement>('[data-field-consent]');
      if (consent && !consent.checked) { setError('consent', messages.consent); firstBad = firstBad || consent; }
      if (firstBad) {
        if (errBox) errBox.hidden = false;
        firstBad.focus();
      }
      return !firstBad;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (okBox) okBox.hidden = true;
      if (failBox) failBox.hidden = true;
      if (!validate()) return;

      submit.disabled = true;
      submit.textContent = messages.sending;
      const data = new URLSearchParams();
      for (const [key, value] of new FormData(form)) data.append(key, String(value));
      // POST to the current page (Netlify intercepts form POSTs by form-name);
      // avoids the forced "/" -> "/pl/" redirect swallowing the submission.
      fetch(location.pathname, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: data.toString() })
        .then(function (res) {
          if (!res.ok) throw new Error('bad status');
          form.reset();
          if (okBox) { okBox.hidden = false; okBox.focus(); }
        })
        .catch(function () { if (failBox) failBox.hidden = false; })
        .finally(function () { submit.disabled = false; submit.textContent = messages.submit; });
    });
  })();
</script>

<style>
  .b2b-enquiry { padding: 32px 0 96px; }
  .b2b-enquiry-head { text-align: center; max-width: 620px; margin: 0 auto 40px; }
  .b2b-section-title { font-size: clamp(1.6rem, 3.6vw, 2.4rem); text-transform: uppercase; }
  .b2b-enquiry-intro { color: var(--text-dim); font-size: 16px; line-height: 1.8; margin-top: 14px; }
  .b2b-form { max-width: 820px; margin: 0 auto; padding: 36px 36px 32px; }
  .b2b-hp { position: absolute; left: -9999px; }
  .b2b-form-hint { font-size: 12px; color: var(--text-faint); margin-bottom: 18px; }
  .b2b-form-errors {
    margin-bottom: 20px; padding: 12px 16px; border-radius: 10px;
    border: 1px solid #a8475f; background: rgba(168,71,95,0.15); color: var(--cream); font-size: 14px;
  }
  .b2b-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 18px 22px; }
  .b2b-fields > *, .b2b-field { min-width: 0; }
  .b2b-field { display: flex; flex-direction: column; gap: 7px; }
  .b2b-field-wide { grid-column: 1 / -1; }
  .b2b-field label { font-size: 13px; color: var(--text-dim); }
  .req { color: var(--gold); }
  .opt { color: var(--text-faint); font-size: 11px; }
  .b2b-field input, .b2b-field select, .b2b-field textarea {
    width: 100%; padding: 11px 13px; border-radius: 9px;
    border: 1px solid var(--line); background: rgba(255,255,255,0.03);
    color: var(--cream); font: inherit; font-size: 14px;
  }
  .b2b-field textarea { resize: vertical; }
  .b2b-field input:focus, .b2b-field select:focus, .b2b-field textarea:focus {
    outline: 2px solid rgba(237,219,194,0.5); outline-offset: 1px; border-color: transparent;
  }
  .b2b-field [aria-invalid='true'] { border-color: #c25c74; }
  .b2b-check { flex-direction: row !important; align-items: center; gap: 11px; font-size: 13px; line-height: 1.5; color: var(--text-faint); cursor: pointer; }
  /* Consent text wraps, so keep its tick aligned to the first line, not centred. */
  .b2b-consent { align-items: flex-start; }
  /* Custom tick: hide the native box and draw our own. */
  .b2b-check input[type="checkbox"] {
    appearance: none; -webkit-appearance: none;
    flex-shrink: 0; width: 18px; height: 18px; margin: 0; padding: 0;
    border: 1px solid var(--line); border-radius: 5px;
    background: rgba(255,255,255,0.03); cursor: pointer; position: relative;
    transition: background 150ms ease, border-color 150ms ease;
  }
  .b2b-consent input[type="checkbox"] { margin-top: 1px; }
  .b2b-check input[type="checkbox"]:hover { border-color: rgba(237,219,194,0.4); }
  .b2b-check input[type="checkbox"]:checked { background: var(--cream); border-color: var(--cream); }
  .b2b-check input[type="checkbox"]:checked::after {
    content: ''; position: absolute; left: 50%; top: 50%;
    width: 4px; height: 8px; border: solid #1a120b; border-width: 0 2px 2px 0;
    transform: translate(-50%, -50%) rotate(45deg);
  }
  .b2b-check input[type="checkbox"]:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
  .b2b-check input[type="checkbox"][aria-invalid='true'] { border-color: #c25c74; }
  .b2b-consent a { color: var(--cream); text-decoration: underline; text-underline-offset: 3px; }
  .b2b-field-error { color: #e7889b; font-size: 12px; }
  .b2b-form-actions { margin-top: 26px; }
  .b2b-form-status { margin-top: 22px; padding: 16px 18px; border-radius: 12px; border: 1px solid var(--line); }
  .b2b-form-status .b2b-status-title { color: var(--cream); font-size: 15px; margin-bottom: 4px; }
  .b2b-form-status .b2b-status-body { color: var(--text-dim); font-size: 14px; line-height: 1.6; }
  .b2b-status-error { border-color: #a8475f; }
  .b2b-status-error a { color: var(--cream); }
  @media (max-width: 640px) { .b2b-fields { grid-template-columns: 1fr; } .b2b-form { padding: 28px 22px; } }
</style>
