---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const f = t.b2b.formats;
---

<section class="b2b-formats">
  <div class="container">
    <h2 class="display b2b-section-title">{f.heading}</h2>
    <p class="b2b-section-intro">{f.intro}</p>
    <ul class="b2b-formats-grid" data-reveal-group>
      {f.items.map((item) => (
        <li class="b2b-format sisi-card">
          <h3 class="b2b-format-title">{item.title}</h3>
          <p class="b2b-format-body">{item.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .b2b-formats { padding: 32px 0 72px; }
  .b2b-section-title { font-size: clamp(1.5rem, 3.4vw, 2.2rem); text-transform: uppercase; text-align: center; margin-bottom: 14px; }
  .b2b-section-intro { text-align: center; color: rgba(237,219,194,0.6); font-size: 15px; line-height: 1.7; max-width: 560px; margin: 0 auto 40px; }
  .b2b-formats-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
  }
  .b2b-format { padding: 26px 24px; }
  .b2b-format-title { font-size: 16px; text-transform: uppercase; letter-spacing: 0.02em; color: var(--cream); margin-bottom: 10px; }
  .b2b-format-body { font-size: 13px; line-height: 1.6; color: rgba(237,219,194,0.55); }
  @media (max-width: 900px) { .b2b-formats-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .b2b-formats-grid { grid-template-columns: 1fr; } }
</style>
