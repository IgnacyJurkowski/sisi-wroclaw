---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const f = t.b2b.formats;

// Icons align by index to formats.items: conference, panel, presentation,
// launch, dinner, networking, party, private brand event. Decorative.
const ICONS = [
  '<path d="M2 3h20"/><path d="M21 3v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V3"/><path d="m7 21 5-5 5 5"/>',
  '<path d="M14 9a2 2 0 0 1-2 2H6l-4 4V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2z"/><path d="M18 9h2a2 2 0 0 1 2 2v11l-4-4h-6a2 2 0 0 1-2-2v-1"/>',
  '<rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
  '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  '<path d="M3 2v7c0 1.1.9 2 2 2h.5c1.1 0 2-.9 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>',
  '<path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/>',
  '<path d="M5.8 11.3 2 22l10.7-3.79"/><path d="M4 3h.01"/><path d="M22 8h.01"/><path d="M15 2h.01"/><path d="M22 20h.01"/><path d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L12 10"/><path d="m22 13-.82-.33c-.86-.34-1.82.2-1.98 1.11c-.11.7-.72 1.22-1.43 1.22H17"/><path d="m11 2 .33.82c.34.86-.2 1.82-1.11 1.98C9.52 4.9 9 5.52 9 6.23V7"/><path d="M11 13c1.93 1.93 2.83 4.17 2 5-.83.83-3.07-.07-5-2-1.93-1.93-2.83-4.17-2-5 .83-.83 3.07.07 5 2Z"/>',
  '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
];
---

<section class="b2b-formats">
  <div class="container">
    <h2 class="display b2b-section-title">{f.heading}</h2>
    <p class="b2b-section-intro">{f.intro}</p>
    <ul class="b2b-formats-grid" data-reveal-group>
      {f.items.map((item, i) => (
        <li class="b2b-format sisi-card">
          <svg class="b2b-format-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS[i]} />
          <h3 class="b2b-format-title">{item.title}</h3>
          <p class="b2b-format-body">{item.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .b2b-formats { padding: 32px 0 72px; }
  .b2b-section-title { font-size: clamp(1.5rem, 3.4vw, 2.2rem); text-transform: uppercase; text-align: center; margin-bottom: 14px; }
  .b2b-section-intro { text-align: center; color: rgba(237,219,194,0.6); font-size: 15px; line-height: 1.7; max-width: 560px; margin: 0 auto 40px; }
  .b2b-formats-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
  }
  .b2b-format { padding: 26px 24px; }
  .b2b-format-icon {
    width: 24px; height: 24px; display: block; margin-bottom: 14px;
    fill: none; stroke: var(--gold); stroke-width: 1.5;
    stroke-linecap: round; stroke-linejoin: round; opacity: 0.9;
  }
  .b2b-format-title { font-size: 16px; text-transform: uppercase; letter-spacing: 0.02em; color: var(--cream); margin-bottom: 10px; }
  .b2b-format-body { font-size: 13px; line-height: 1.6; color: rgba(237,219,194,0.55); }
  @media (max-width: 900px) { .b2b-formats-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .b2b-formats-grid { grid-template-columns: 1fr; } }
</style>
