---
import { type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/t';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const w = t.b2b.why;

// Icons align by index to why.items: both-in-one-place, central location,
// restaurant + club, flexible format, two screens, direct team contact.
const ICONS = [
  '<path d="M10 18H5a3 3 0 0 1-3-3v-1"/><path d="M14 2a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/><path d="m7 21 3-3-3-3"/><rect x="14" y="14" width="8" height="8" rx="2"/>',
  '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
  '<path d="m16 2-2.3 2.3a3 3 0 0 0 0 4.2l1.8 1.8a3 3 0 0 0 4.2 0L22 8"/><path d="M15 15 3.3 3.3a4.2 4.2 0 0 0 0 6l7.3 7.3c.7.7 2 .7 2.8 0L15 15Zm0 0 7 7"/><path d="m2.1 21.8 6.4-6.3"/><path d="m19 5-7 7"/>',
  '<path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/>',
  '<path d="M2 3h20"/><path d="M21 3v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V3"/><path d="m7 21 5-5 5 5"/>',
  '<path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H4a1 1 0 0 1-1-1v-4a8 8 0 0 1 16 0v4a1 1 0 0 1-1 1h-2a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/><path d="M21 16v2a4 4 0 0 1-4 4h-5"/>',
];
---

<section class="b2b-why">
  <div class="container">
    <h2 class="display b2b-section-title">{w.heading}</h2>
    <ul class="b2b-why-grid" data-reveal-group>
      {w.items.map((item, i) => (
        <li class="b2b-why-item sisi-card">
          <svg class="b2b-why-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS[i]} />
          <div>
            <h3 class="b2b-why-title">{item.title}</h3>
            <p class="b2b-why-body">{item.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .b2b-why { padding: 32px 0 72px; }
  .b2b-section-title { font-size: clamp(1.5rem, 3.4vw, 2.2rem); text-transform: uppercase; text-align: center; margin-bottom: 36px; }
  .b2b-why-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
  }
  .b2b-why-item { padding: 26px 24px; display: flex; gap: 16px; align-items: flex-start; }
  .b2b-why-icon {
    width: 24px; height: 24px; flex-shrink: 0; margin-top: 2px;
    fill: none; stroke: var(--gold); stroke-width: 1.5;
    stroke-linecap: round; stroke-linejoin: round; opacity: 0.9;
  }
  .b2b-why-title { font-size: 15px; text-transform: uppercase; letter-spacing: 0.02em; color: var(--cream); margin-bottom: 8px; line-height: 1.3; }
  .b2b-why-body { font-size: 13px; line-height: 1.6; color: rgba(237,219,194,0.55); }
  @media (max-width: 900px) { .b2b-why-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .b2b-why-grid { grid-template-columns: 1fr; } }
</style>
